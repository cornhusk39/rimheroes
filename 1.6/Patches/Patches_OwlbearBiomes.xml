<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Owlbears stalk the forests, rarely. -->

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="TemperateForest"]/wildAnimals</xpath>
    <value>
      <RH_OwlbearKind>0.02</RH_OwlbearKind>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="BorealForest"]/wildAnimals</xpath>
    <value>
      <RH_OwlbearKind>0.03</RH_OwlbearKind>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="TropicalRainforest"]/wildAnimals</xpath>
    <value>
      <RH_OwlbearKind>0.015</RH_OwlbearKind>
    </value>
  </Operation>

  <!-- Dire wolves: cold forests and tundra -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="BorealForest"]/wildAnimals</xpath>
    <value>
      <RH_DireWolfKind>0.05</RH_DireWolfKind>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="Tundra"]/wildAnimals</xpath>
    <value>
      <RH_DireWolfKind>0.06</RH_DireWolfKind>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="TemperateForest"]/wildAnimals</xpath>
    <value>
      <RH_DireWolfKind>0.03</RH_DireWolfKind>
    </value>
  </Operation>

  <!-- Giant elk: the cold north -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="BorealForest"]/wildAnimals</xpath>
    <value>
      <RH_GiantElkKind>0.04</RH_GiantElkKind>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="Tundra"]/wildAnimals</xpath>
    <value>
      <RH_GiantElkKind>0.05</RH_GiantElkKind>
    </value>
  </Operation>

  <!-- Ankhegs: dry scrub and farmable lowlands -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="AridShrubland"]/wildAnimals</xpath>
    <value>
      <RH_AnkhegKind>0.03</RH_AnkhegKind>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="TemperateForest"]/wildAnimals</xpath>
    <value>
      <RH_AnkhegKind>0.01</RH_AnkhegKind>
    </value>
  </Operation>

  <!-- Basilisks: deserts and jungle deeps -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="Desert"]/wildAnimals</xpath>
    <value>
      <RH_BasiliskKind>0.03</RH_BasiliskKind>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/BiomeDef[defName="TropicalRainforest"]/wildAnimals</xpath>
    <value>
      <RH_BasiliskKind>0.02</RH_BasiliskKind>
    </value>
  </Operation>

</Patch>
