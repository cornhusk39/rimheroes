<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Tier-5 capstone aura motes: small additive glyphs that drift up off the hero, tinted
       per class via instanceColor. Shape carries the class identity. -->
  <FleckDef Name="RH_AuraMoteBase" Abstract="True">
    <fleckSystemClass>FleckSystemThrown</fleckSystemClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.15</fadeInTime>
    <solidTime>0.18</solidTime>
    <fadeOutTime>0.9</fadeOutTime>
    <graphicData>
      <graphicClass>Graphic_Fleck</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>0.6</drawSize>
    </graphicData>
  </FleckDef>

  <!-- generic soft dot (fallback) -->
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_AuraMote</defName>
    <graphicData>
      <texPath>Things/RimHeroes/Vestments/Effects/Mote_Orb</texPath>
    </graphicData>
  </FleckDef>

  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Ember</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Ember</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Spark</defName>
