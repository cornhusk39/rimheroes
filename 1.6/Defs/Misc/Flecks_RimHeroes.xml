<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Tier-5 capstone aura motes: small additive glyphs that drift up off the hero, tinted
       per class via instanceColor. Shape carries the class identity. -->
  <FleckDef Name="RH_AuraMoteBase" Abstract="True">
    <fleckSystemClass>FleckSystemThrown</fleckSystemClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.15</fadeInTime>
    <solidTime>0.18</solidTime>
    <fadeOutTime>0.9</fadeOutTime>
    <graphicData>
      <graphicClass>Graphic_Fleck</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>0.6</drawSize>
    </graphicData>
  </FleckDef>

  <!-- generic soft dot (fallback) -->
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_AuraMote</defName>
    <graphicData>
      <texPath>Things/RimHeroes/Vestments/Effects/Mote_Orb</texPath>
    </graphicData>
  </FleckDef>

  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Ember</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Ember</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Spark</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Spark</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Star</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Star</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Note</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Note</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Leaf</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Leaf</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Feather</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Feather</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Wisp</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Wisp</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Orb</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Orb</texPath></graphicData>
  </FleckDef>

  <!-- Wildshape cast: a soft purple gas cloud that billows out and fades. Transparent (not additive)
       so it reads as smoke, not a glow. Tinted purple per-instance in Wildshape.PlayShiftFx. -->
  <FleckDef>
    <defName>RH_Fleck_WildshapeGas</defName>
    <fleckSystemClass>FleckSystemThrown</fleckSystemClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.12</fadeInTime>
    <solidTime>0.1</solidTime>
    <fadeOutTime>0.75</fadeOutTime>
    <growthRate>0.6</growthRate>
    <graphicData>
      <graphicClass>Graphic_Fleck</graphicClass>
      <shaderType>Transparent</shaderType>
      <texPath>Things/RimHeroes/Vestments/Effects/Mote_Cloud</texPath>
      <drawSize>1.0</drawSize>
    </graphicData>
  </FleckDef>

  <!-- Heal bloom: a soft glow at a healed pawn's feet that radiates outward over ~0.8s. Tinted green
       (or radiant) per instance. -->
  <FleckDef>
    <defName>RH_Fleck_HealBloom</defName>
    <fleckSystemClass>FleckSystemThrown</fleckSystemClass>
    <altitudeLayer>MoteLow</altitudeLayer>
    <fadeInTime>0.1</fadeInTime>
    <solidTime>0.15</solidTime>
    <fadeOutTime>0.55</fadeOutTime>
    <growthRate>1.6</growthRate>
    <graphicData>
      <graphicClass>Graphic_Fleck</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <texPath>Things/RimHeroes/Vestments/Effects/AuraGlow</texPath>
      <drawSize>1.0</drawSize>
    </graphicData>
  </FleckDef>

  <!-- Range ring: a thin circular outline drawn at the caster for ~0.8s to show a radius spell's reach.
       Non-glowing (Transparent), scaled to 2*radius and tinted at ~60% alpha per instance. -->
  <FleckDef>
    <defName>RH_Fleck_RangeRing</defName>
    <fleckSystemClass>FleckSystemThrown</fleckSystemClass>
    <altitudeLayer>MoteLow</altitudeLayer>
    <fadeInTime>0.12</fadeInTime>
    <solidTime>0.3</solidTime>
    <fadeOutTime>0.38</fadeOutTime>
    <graphicData>
      <graphicClass>Graphic_Fleck</graphicClass>
      <shaderType>Transparent</shaderType>
      <texPath>Things/RimHeroes/Effects/RangeRing</texPath>
      <drawSize>1.0</drawSize>
    </graphicData>
  </FleckDef>

</Defs>
