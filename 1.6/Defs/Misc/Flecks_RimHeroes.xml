  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Note</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Note</texPath></graphicData>
  </FleckDef>
  <FleckDef ParentName="RH_AuraMoteBase">
    <defName>RH_Mote_Leaf</defName>
    <graphicData><texPath>Things/RimHeroes/Vestments/Effects/Mote_Leaf</texPath></graphicData>
  </FleckDef>
