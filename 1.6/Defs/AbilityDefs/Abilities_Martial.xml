  <!-- Monk Stunning Strike -->
  <AbilityDef ParentName="RH_MartialBase">
    <defName>RH_Ability_StunningStrike</defName>
    <label>stunning strike</label>
    <description>A precise blow that briefly stuns a foe.</description>
    <iconPath>UI/RimHeroes/StunningStrike</iconPath>
    <cooldownTicksRange>600</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>6.9</range>
      <warmupTime>0.2</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetPawns>true</canTargetPawns><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityZoneHediff">
        <hediff>RH_Stunned</hediff>
        <radius>1.5</radius>
        <targets>Enemies</targets>
      </li>
    </comps>
  </AbilityDef>

