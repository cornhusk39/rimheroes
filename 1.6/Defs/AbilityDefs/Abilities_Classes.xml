<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Spell kits for the remaining caster classes. Icons are real RH art under UI/RimHeroes/. -->

  <!-- ===== Cantrips ===== -->

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_SacredFlame</defName>
    <label>sacred flame</label>
    <description>Call down a flicker of radiant fire onto a foe. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/SacredFlame</iconPath>
    <level>0</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>19.9</range>
      <warmupTime>0.6</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Flame</damageDef>
        <amount>8</amount>
        <hits>1</hits>
        <flashColor>(1.0, 0.95, 0.7)</flashColor>
        <downColumnColor>(1.0, 0.97, 0.75)</downColumnColor>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_ViciousMockery</defName>
    <label>vicious mockery</label>
    <description>A cutting insult laced with subtle enchantment, sharp enough to draw real blood. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/ViciousMockery</iconPath>
    <level>0</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>19.9</range>
      <warmupTime>0.5</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>false</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Stun</damageDef>
        <amount>14</amount>
        <hits>1</hits>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_EldritchBlast</defName>
    <label>eldritch blast</label>
    <description>A crackling beam of otherworldly force, the signature strike of every warlock's pact. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/EldritchBlast</iconPath>
    <level>0</level>
    <cooldownTicksRange>90</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>27.9</range>
      <warmupTime>0.5</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetBuildings>true</canTargetBuildings>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <!-- A hitscan crackling red beam snapped from caster to target (drawn unstable + jittering in
           MapComponent_SpellBeams), with Spell-Power-scaled damage. Replaces the borrowed projectile. -->
      <li Class="RimHeroes.CompProperties_AbilityBeam">
        <damageDef>Burn</damageDef>
        <amount>14</amount>
        <color>(0.95, 0.16, 0.12, 1)</color>
        <ticks>26</ticks>
        <width>0.36</width>
      </li>
    </comps>
  </AbilityDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RH_Projectile_EldritchBlast</defName>
    <label>eldritch blast</label>
    <graphicData>
      <texPath>Things/Projectile/LauncherShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <color>(0.6, 0.3, 0.9)</color>
    </graphicData>
    <projectile>
      <damageDef>Blunt</damageDef>
      <damageAmountBase>14</damageAmountBase>
      <speed>50</speed>
      <armorPenetrationBase>0.4</armorPenetrationBase>
    </projectile>
  </ThingDef>

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_Thornlash</defName>
    <label>thornlash</label>
    <description>A whip of thorned vine lashes out to rake a nearby foe. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/Thornlash</iconPath>
    <level>0</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>14.9</range>
      <warmupTime>0.5</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Stab</damageDef>
        <amount>10</amount>
        <hits>1</hits>
      </li>
    </comps>
  </AbilityDef>

  <!-- ===== Healing ===== -->

  <AbilityDef Name="RH_HealBase" ParentName="RH_SpellBase" Abstract="True">
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <cooldownTicksRange>60</cooldownTicksRange>
  </AbilityDef>

  <AbilityDef ParentName="RH_HealBase">
    <defName>RH_Spell_CureWounds</defName>
    <label>cure wounds</label>
    <description>Close wounds with a touch. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/CureWounds</iconPath>
    <level>1</level>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>3.9</range>
      <warmupTime>1</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityHeal">
        <amount>18</amount>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef ParentName="RH_HealBase">
    <defName>RH_Spell_HealingWord</defName>
    <label>healing word</label>
    <description>A word of power that knits flesh at a distance. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/HealingWord</iconPath>
    <level>1</level>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>22.9</range>
      <warmupTime>0.6</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityHeal">
        <amount>12</amount>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef ParentName="RH_HealBase">
    <defName>RH_Spell_LayOnHands</defName>
    <label>lay on hands</label>
    <description>Channel divine vitality through your palms. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/LayOnHands</iconPath>
    <level>1</level>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>3.9</range>
      <warmupTime>1</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityHeal">
        <amount>25</amount>
      </li>
    </comps>
  </AbilityDef>

  <!-- ===== Buffs / marks ===== -->

  <AbilityDef ParentName="RH_HealBase">
    <defName>RH_Spell_Bless</defName>
    <label>bless</label>
    <description>Bless an ally: their strikes land truer for a time. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/Bless</iconPath>
    <level>1</level>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>22.9</range>
      <warmupTime>0.8</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_Blessed</hediffDef>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <HediffDef>
    <defName>RH_Blessed</defName>
    <label>blessed</label>
    <description>Guided by a higher hand: attacks land truer, nerves hold steadier.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.9, 0.6)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MeleeHitChance>4</MeleeHitChance>
          <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
          <MentalBreakThreshold>-0.05</MentalBreakThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>7500</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_HuntersMark</defName>
    <label>hunter's mark</label>
    <description>Mark a quarry: it takes more harm from every blow while marked. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/HuntersMark</iconPath>
    <level>1</level>
    <cooldownTicksRange>60</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>29.9</range>
      <warmupTime>0.6</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_Marked</hediffDef>
        <replaceExisting>true</replaceExisting>
        <applyToSelf>false</applyToSelf>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_Hex</defName>
    <label>hex</label>
    <description>Lay a withering curse on a foe: it takes more harm from every blow while hexed. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/Hex</iconPath>
    <level>1</level>
    <cooldownTicksRange>60</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>27.9</range>
      <warmupTime>0.6</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_Marked</hediffDef>
        <replaceExisting>true</replaceExisting>
        <applyToSelf>false</applyToSelf>
      </li>
    </comps>
  </AbilityDef>

  <HediffDef>
    <defName>RH_Marked</defName>
    <label>marked</label>
    <description>Marked by a hunter's spell or a warlock's curse. Every wound bites deeper.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.4, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statFactors>
          <IncomingDamageFactor>1.2</IncomingDamageFactor>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>7500</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- ===== Revival ===== -->

  <AbilityDef ParentName="RH_HealBase">
    <defName>RH_Spell_Revivify</defName>
    <label>revivify</label>
    <description>Call a soul back to a body that died within the last day. The fresher, the better. Consumes a level-3 spell slot.</description>
    <iconPath>UI/RimHeroes/Revivify</iconPath>
    <level>3</level>
    <cooldownTicksRange>2500</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>3.9</range>
      <warmupTime>3</warmupTime>
      <targetParams>
        <canTargetPawns>false</canTargetPawns>
        <canTargetSelf>false</canTargetSelf>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetItems>true</canTargetItems>
        <mapObjectTargetsMustBeAutoAttackable>false</mapObjectTargetsMustBeAutoAttackable>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityRevivify">
        <maxDeathTicks>60000</maxDeathTicks>
      </li>
    </comps>
  </AbilityDef>

</Defs>
