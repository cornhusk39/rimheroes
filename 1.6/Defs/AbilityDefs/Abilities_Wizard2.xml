<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Wizard spell list, cantrip -> level 9. Built on proven comps (our SpellPower-scaling
       DamageTarget/Explosion/ZoneHediff plus vanilla GiveHediff/Teleport/FireBurst). All text
       original and functional - no rulebook wording. Granted via the Wizard's levelGrants. -->

  <!-- ============ CANTRIPS (level 0, at-will) ============ -->

  <!-- Shocking Grasp: touch-range zap that staggers -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_ShockingGrasp</defName>
    <label>shocking grasp</label>
    <description>Loose a jolt of lightning into a foe at close range, leaving them twitching. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/ShockingGrasp</iconPath>
    <level>0</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>6.9</range>
      <warmupTime>0.4</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetPawns>true</canTargetPawns><canTargetAnimals>true</canTargetAnimals><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Burn</damageDef>
        <amount>8</amount>
        <hits>1</hits>
        <applyHediff>RH_Jolted</applyHediff>
      </li>
    </comps>
  </AbilityDef>

  <!-- Toll the Dead: withering toll, far worse against the already-wounded -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_TollTheDead</defName>
    <label>toll the dead</label>
    <description>A mournful bell only the target hears wracks them with pain, and bites far deeper into one already wounded. Cantrip, costs no spell slot.</description>
    <iconPath>UI/RimHeroes/TollTheDead</iconPath>
    <level>0</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>21.9</range>
      <warmupTime>0.6</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetPawns>true</canTargetPawns><canTargetAnimals>true</canTargetAnimals><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <amount>6</amount>
        <hits>1</hits>
        <bonusVsWoundedFactor>1.2</bonusVsWoundedFactor>
      </li>
    </comps>
  </AbilityDef>

  <!-- ============ LEVEL 1 ============ -->

  <!-- Thunderwave: a concussive burst around a point -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_Thunderwave</defName>
    <label>thunderwave</label>
    <description>A wave of thunderous force slams outward, battering everything caught in it. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/Thunderwave</iconPath>
    <level>1</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>9.9</range>
      <warmupTime>0.8</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetLocations>true</canTargetLocations><canTargetPawns>true</canTargetPawns><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityExplosion">
        <damageDef>Blunt</damageDef>
        <radius>2.9</radius>
        <damageAmount>12</damageAmount>
      </li>
    </comps>
  </AbilityDef>

  <!-- Chromatic Orb: a heavy single bolt of raw elemental energy -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_ChromaticOrb</defName>
    <label>chromatic orb</label>
    <description>Hurl an orb of churning elemental energy that bursts against a single foe. Consumes a level-1 spell slot.</description>
    <iconPath>UI/RimHeroes/ChromaticOrb</iconPath>
    <level>1</level>
    <cooldownTicksRange>90</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>24.9</range>
      <warmupTime>1</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetPawns>true</canTargetPawns><canTargetAnimals>true</canTargetAnimals><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Burn</damageDef>
        <amount>18</amount>
        <hits>1</hits>
      </li>
    </comps>
  </AbilityDef>

  <!-- ============ LEVEL 2 ============ -->

  <!-- Scorching Ray: three fiery darts -->
