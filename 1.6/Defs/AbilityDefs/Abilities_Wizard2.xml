  <!-- ============ LEVEL 4 ============ -->

  <!-- Ice Storm: battering hail that chills the field -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_IceStorm</defName>
    <label>ice storm</label>
    <description>A pounding storm of ice hammers a patch of ground and leaves survivors numb and slow. Consumes a level-4 spell slot.</description>
    <iconPath>UI/RimHeroes/IceStorm</iconPath>
    <level>4</level>
    <cooldownTicksRange>200</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
