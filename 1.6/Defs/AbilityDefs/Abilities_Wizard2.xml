    </comps>
  </AbilityDef>

  <!-- ============ LEVEL 6 ============ -->

  <!-- Disintegrate: a thin green ray that unmakes a single target -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_Disintegrate</defName>
    <label>disintegrate</label>
