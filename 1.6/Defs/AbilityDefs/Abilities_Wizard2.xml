    <defName>RH_Spell_ScorchingRay</defName>
    <label>scorching ray</label>
    <description>Three rays of fire streak from your hand to scorch a target. Consumes a level-2 spell slot.</description>
    <iconPath>UI/RimHeroes/ScorchingRay</iconPath>
    <level>2</level>
    <cooldownTicksRange>120</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>24.9</range>
      <warmupTime>1</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetPawns>true</canTargetPawns><canTargetAnimals>true</canTargetAnimals><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="RimHeroes.CompProperties_AbilityDamageTarget">
        <damageDef>Burn</damageDef>
        <amount>7</amount>
        <hits>3</hits>
      </li>
    </comps>
  </AbilityDef>

  <!-- Misty Step: a short blink to a chosen spot -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_MistyStep</defName>
    <label>misty step</label>
    <description>Vanish in a curl of silvery mist and reappear at a nearby spot you can see. Consumes a level-2 spell slot.</description>
    <iconPath>UI/RimHeroes/MistyStep</iconPath>
    <level>2</level>
    <cooldownTicksRange>200</cooldownTicksRange>
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>24.9</range>
      <warmupTime>0.3</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetLocations>true</canTargetLocations><canTargetPawns>false</canTargetPawns><canTargetSelf>false</canTargetSelf></targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityTeleport">
        <compClass>CompAbilityEffect_Teleport</compClass>
        <destination>Selected</destination>
        <requiresLineOfSight>true</requiresLineOfSight>
        <range>24.9</range>
      </li>
    </comps>
  </AbilityDef>

  <!-- Mirror Image: decoy duplicates -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_MirrorImage</defName>
    <label>mirror image</label>
    <description>Conjure flickering duplicates of yourself that draw away incoming blows. Consumes a level-2 spell slot.</description>
    <iconPath>UI/RimHeroes/MirrorImage</iconPath>
    <level>2</level>
    <cooldownTicksRange>200</cooldownTicksRange>
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>-1</range>
      <warmupTime>0.5</warmupTime>
      <targetParams><canTargetSelf>true</canTargetSelf><canTargetPawns>false</canTargetPawns><canTargetLocations>false</canTargetLocations></targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_MirrorImage</hediffDef>
        <onlyApplyToSelf>true</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <!-- ============ LEVEL 3 ============ -->

  <!-- Lightning Bolt: a heavy single strike that staggers -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_LightningBolt</defName>
