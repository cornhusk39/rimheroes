  <!-- Slow: bog down a cluster of enemies -->
  <AbilityDef ParentName="RH_SpellBase">
    <defName>RH_Spell_Slow</defName>
    <label>slow</label>
    <description>Warp the flow of time around a group of foes so their every move drags. Consumes a level-4 spell slot.</description>
    <iconPath>UI/RimHeroes/Slow</iconPath>
    <level>4</level>
    <cooldownTicksRange>300</cooldownTicksRange>
    <hostile>true</hostile>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>29.9</range>
      <warmupTime>1.2</warmupTime>
      <requireLineOfSight>true</requireLineOfSight>
      <targetParams><canTargetLocations>true</canTargetLocations><canTargetPawns>true</canTargetPawns><canTargetSelf>false</canTargetSelf></targetParams>
