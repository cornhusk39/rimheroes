<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Wildshape forms: free abilities (no slot), at-will with a long cooldown; duration via
       HediffComp_Disappears, manual revert via the hediff's gizmo, one form at a time.
       Form ladder: displacer beast L2, owlbear L5, basilisk L8. All form art is from Mooloh's
       Dnd Menagerie (hard dependency). -->

  <AbilityDef Name="RH_WildshapeBase" ParentName="RH_SpellBase" Abstract="True">
    <level>0</level>
    <cooldownTicksRange>30000</cooldownTicksRange>
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>-1</range>
      <warmupTime>1</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetLocations>false</canTargetLocations>
      </targetParams>
    </verbProperties>
  </AbilityDef>

  <!-- Displacer beast: fast skirmisher form -->
  <AbilityDef ParentName="RH_WildshapeBase">
    <defName>RH_Ability_WildshapeDireWolf</defName>
    <label>wildshape: displacer beast</label>
    <description>Take the shape of a displacer beast for a few hours: a six-legged panther wreathed in shadow, here and not quite here, lashing with barbed tentacles. Weapons and apparel are subsumed into the form. Costs no spell slot.</description>
    <iconPath>UI/RimHeroes/WildshapeDireWolf</iconPath>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_WildshapeDireWolf</hediffDef>
        <onlyApplyToSelf>true</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <HediffDef>
    <defName>RH_WildshapeDireWolf</defName>
    <label>displacer beast form</label>
    <description>This druid wears the shape of a displacer beast: swift, shadow-clad, and armed with lashing barbed tentacles. Their gear is subsumed into the form.</description>
    <hediffClass>RimHeroes.Hediff_Wildshape</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.4, 0.75, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>1.6</MoveSpeed>
          <ArmorRating_Sharp>0.05</ArmorRating_Sharp>
          <PainShockThreshold>0.1</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>10000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_VerbGiver">
        <tools>
          <li>
            <label>displacer beast tentacle</label>
            <capacities>
              <li>Bite</li>
            </capacities>
            <power>19</power>
            <cooldownTime>2</cooldownTime>
          </li>
        </tools>
      </li>
      <li Class="RimHeroes.HediffCompProperties_GrantAbility"><ability>RH_Ability_Pounce</ability></li>
    </comps>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_Wildshape</nodeClass>
        <texPath>Things/Pawn/Animal/DND_DisplacerBeast/DND_DisplacerBeast</texPath>
        <parentTagDef>Root</parentTagDef>
        <drawSize>(2.0, 2.0)</drawSize>
        <drawData>
          <defaultData>
            <layer>40</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

  <!-- Basilisk: heavy charging form -->
  <AbilityDef ParentName="RH_WildshapeBase">
    <defName>RH_Ability_WildshapeGiantElk</defName>
    <label>wildshape: basilisk</label>
    <description>Take the shape of a basilisk for a few hours: a low, armoured reptile that batters everything in its path. Weapons and apparel are subsumed into the form. Costs no spell slot.</description>
    <iconPath>UI/RimHeroes/WildshapeGiantElk</iconPath>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_WildshapeGiantElk</hediffDef>
        <onlyApplyToSelf>true</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <HediffDef>
    <defName>RH_WildshapeGiantElk</defName>
    <label>basilisk form</label>
    <description>This druid wears the shape of a basilisk: low, armoured, and strong enough to bowl through a line and carry a heavy load. Their gear is subsumed into the form.</description>
    <hediffClass>RimHeroes.Hediff_Wildshape</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.4, 0.75, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>2.4</MoveSpeed>
          <CarryingCapacity>40</CarryingCapacity>
          <PainShockThreshold>0.1</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>10000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_VerbGiver">
        <tools>
          <li>
            <label>basilisk headbutt</label>
            <capacities>
              <li>Blunt</li>
            </capacities>
            <power>20</power>
            <cooldownTime>2.3</cooldownTime>
          </li>
        </tools>
      </li>
      <li Class="RimHeroes.HediffCompProperties_GrantAbility"><ability>RH_Ability_Trample</ability></li>
    </comps>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_Wildshape</nodeClass>
        <texPath>Things/Pawn/Animal/DND_Basilisk/DND_Basilisk</texPath>
        <parentTagDef>Root</parentTagDef>
        <drawSize>(2.5, 2.5)</drawSize>
        <drawData>
          <defaultData>
            <layer>40</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

  <!-- Owlbear: heavy combat form -->
  <AbilityDef ParentName="RH_WildshapeBase">
    <defName>RH_Ability_WildshapeOwlbear</defName>
    <label>wildshape: owlbear</label>
    <description>Take the shape of an owlbear for a few hours: a feathered engine of claws and beak. Weapons and apparel are subsumed into the form. Costs no spell slot.</description>
    <iconPath>UI/RimHeroes/WildshapeOwlbear</iconPath>
    <level>0</level>
    <cooldownTicksRange>30000</cooldownTicksRange>
    <hostile>false</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>-1</range>
      <warmupTime>1</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetLocations>false</canTargetLocations>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>RH_WildshapeOwlbear</hediffDef>
        <onlyApplyToSelf>true</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <HediffDef>
    <defName>RH_WildshapeOwlbear</defName>
    <label>owlbear form</label>
    <description>This druid wears the shape of an owlbear: massive, feathered, and armed with rending claws and a cracking beak. Their gear is subsumed into the form.</description>
    <hediffClass>RimHeroes.Hediff_Wildshape</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.4, 0.75, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>1.0</MoveSpeed>
          <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.15</ArmorRating_Blunt>
          <PainShockThreshold>0.2</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>10000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_VerbGiver">
        <tools>
          <li>
            <label>owlbear claw</label>
            <capacities>
              <li>Scratch</li>
            </capacities>
            <power>18</power>
            <cooldownTime>2</cooldownTime>
          </li>
          <li>
            <label>owlbear beak</label>
            <capacities>
              <li>Bite</li>
            </capacities>
            <power>25</power>
            <cooldownTime>2.6</cooldownTime>
            <chanceFactor>0.7</chanceFactor>
          </li>
        </tools>
      </li>
      <li Class="RimHeroes.HediffCompProperties_GrantAbility"><ability>RH_Ability_Rend</ability></li>
    </comps>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_Wildshape</nodeClass>
        <texPath>Things/Pawn/Animal/DND_Owlbear/DND_Owlbear</texPath>
        <parentTagDef>Root</parentTagDef>
        <drawSize>(2.4, 2.4)</drawSize>
        <drawData>
          <defaultData>
            <layer>40</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

</Defs>
