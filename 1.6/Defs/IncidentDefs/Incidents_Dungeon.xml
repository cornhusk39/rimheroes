<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- A dungeon entrance opens on the colony map (it then trickles monsters until delved or destroyed). -->
  <IncidentDef>
    <defName>RH_Incident_CryptEntrance</defName>
    <label>dungeon entrance</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>RimHeroes.IncidentWorker_DungeonEntrance</workerClass>
    <baseChance>0.6</baseChance>
    <minRefireDays>15</minRefireDays>
    <letterDef>NeutralEvent</letterDef>
  </IncidentDef>

  <!-- An evil party of enemy heroes raids the colony (used by the capstone quest's CreateIncidents). -->
  <IncidentDef>
    <defName>RH_Incident_HeroRaid</defName>
    <label>adventuring party raid</label>
    <category>ThreatBig</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>RimHeroes.IncidentWorker_HeroRaid</workerClass>
    <baseChance>0</baseChance>
  </IncidentDef>

  <!-- Word of a dungeon out in the world: spawns a visitable site to caravan to. -->
  <IncidentDef>
    <defName>RH_Incident_DungeonQuest</defName>
    <label>dungeon discovered</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>RimHeroes.IncidentWorker_DungeonQuest</workerClass>
    <baseChance>0.5</baseChance>
    <minRefireDays>20</minRefireDays>
  </IncidentDef>

</Defs>
