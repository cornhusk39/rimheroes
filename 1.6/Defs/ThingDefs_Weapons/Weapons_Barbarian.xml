<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Shared base for class-locked hero melee weapons: fixed power (no stuff/quality), bound items. -->
  <ThingDef Name="RH_HeroWeaponMeleeBase" ParentName="BaseWeapon" Abstract="True">
    <techLevel>Medieval</techLevel>
    <smeltable>false</smeltable>
    <burnableByRecipe>false</burnableByRecipe>
    <destroyOnDrop>false</destroyOnDrop>
    <tradeability>None</tradeability>
    <equippedAngleOffset>0</equippedAngleOffset>
    <weaponClasses>
      <li>Melee</li>
    </weaponClasses>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MaxHitPoints>220</MaxHitPoints>
      <Mass>3.5</Mass>
      <Flammability>0.4</Flammability>
    </statBases>
    <comps>
      <li><compClass>CompQuality</compClass></li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Barbarian_T1</defName>
    <label>lesser hero greataxe</label>
    <description>A crude two-handed greataxe, heavier in the head and keener at the edge than any axe a smith would call common. It is bound to a hero barbarian's rage, and no one else can heft it in anger.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Barbarian/T1</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.10</drawSize></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>haft</label><capacities><li>Blunt</li></capacities><power>12</power><cooldownTime>2.4</cooldownTime></li>
      <li><label>blade</label><capacities><li>Cut</li></capacities><power>27</power><cooldownTime>2.5</cooldownTime><armorPenetration>0.25</armorPenetration></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Barbarian</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Barbarian_T2</defName>
    <label>hero greataxe</label>
    <description>A masterwork steel greataxe cut with a single rune of fury along the cheek. It bites deeper and tracks truer through a swing than any lesser blade.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Barbarian/T2</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.10</drawSize></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>haft</label><capacities><li>Blunt</li></capacities><power>15</power><cooldownTime>2.4</cooldownTime></li>
      <li><label>blade</label><capacities><li>Cut</li></capacities><power>36</power><cooldownTime>2.5</cooldownTime><armorPenetration>0.34</armorPenetration></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Barbarian</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Barbarian_T3</defName>
    <label>greater hero greataxe</label>
    <description>A gold-bound greataxe set with a blood-ruby, its edges humming with held-back power. Plate splits before it like wet cloth.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Barbarian/T3</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.15</drawSize></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>haft</label><capacities><li>Blunt</li></capacities><power>19</power><cooldownTime>2.3</cooldownTime></li>
      <li><label>blade</label><capacities><li>Cut</li></capacities><power>47</power><cooldownTime>2.5</cooldownTime><armorPenetration>0.45</armorPenetration></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Barbarian</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Barbarian_T4</defName>
    <label>perfect hero greataxe</label>
    <description>A greataxe sheathed in molten runelight, its spiked bits keening with bound fire. Almost nothing on two legs walks away from a full swing.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Barbarian/T4</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.25</drawSize></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>haft</label><capacities><li>Blunt</li></capacities><power>24</power><cooldownTime>2.3</cooldownTime></li>
      <li><label>blade</label><capacities><li>Cut</li></capacities><power>60</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.58</armorPenetration></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Barbarian</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Barbarian_T5</defName>
    <label>Worldcleaver</label>
    <description>The barbarian's capstone greataxe, taken up only by a hero whose legend has run its full length. The molten heart of the blade never cools, and a single swing parts earth and army with the same indifference.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Barbarian/T5</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.40</drawSize></graphicData>
    <statBases><MarketValue>9000</MarketValue><Mass>4.2</Mass></statBases>
    <tools>
      <li><label>haft</label><capacities><li>Blunt</li></capacities><power>30</power><cooldownTime>2.2</cooldownTime></li>
      <li><label>blade</label><capacities><li>Cut</li></capacities><power>78</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.72</armorPenetration></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Barbarian</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
