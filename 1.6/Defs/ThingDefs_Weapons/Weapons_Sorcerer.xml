<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Sorcerer_T1</defName>
    <label>lesser hero scepter</label>
    <description>A plain dark rod crowned with a small red gem, a focus through which a hero sorcerer channels their innate magic. A poor club, but it sharpens the will behind a spell.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Sorcerer/T1</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>8</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Sorcerer</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Sorcerer_T2</defName>
    <label>hero scepter</label>
    <description>A gold-banded scepter set with a large crimson gem. The bound metal hums faintly when magic flows through it, lending greater force to every spell.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Sorcerer/T2</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>9</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Sorcerer</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Sorcerer_T3</defName>
    <label>greater hero scepter</label>
    <description>An ornate scepter cradling a faceted crimson crystal in golden claws. A faint crackle of energy dances at its crown, drawn out by the sorcerer's growing power.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Sorcerer/T3</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>11</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.50</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Sorcerer</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Sorcerer_T4</defName>
    <label>perfect hero scepter</label>
    <description>A scepter wreathed in arcing gold sparks, its glowing gem haloed in raw magic. In a hero's grip it makes spells erupt with brutal, near-uncontrollable force.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Sorcerer/T4</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>13</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.75</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Sorcerer</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Sorcerer_T5</defName>
    <label>Bloodfire Scepter</label>
    <description>The capstone scepter of the sorcerer, won only by a hero who has reached the height of their legend. Molten crimson-gold bloodfire erupts from its gem and never dies; the spells it focuses fall on the world like a burning storm.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Sorcerer/T5</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>9000</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>16</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>1.0</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Sorcerer</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
