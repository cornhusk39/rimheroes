<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Class-locked hero staves for the wizard. Caster focus: weak melee, the power is in spell amplification (RH_SpellPower). Base RH_HeroWeaponMeleeBase is defined in Weapons_Barbarian.xml. -->

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_TierI</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>lesser hero staff</label>
    <description>A plain wooden staff with a small bound stone lashed at its head. It makes a poor club, but in a hero wizard's grip it gathers the weave and lends real weight to their spells.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T1</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>8</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_TierII</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>hero staff</label>
    <description>A silver-shod staff crowned with a cut blue gem. The stone draws in the mana around it and sharpens every incantation its bearer speaks.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T2</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>9</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_TierIII</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>greater hero staff</label>
    <description>An ornate staff whose silver claws hold a floating orb that never quite settles into them. A faint arcane glow trails the bearer, and their spells land with a scholar's precision.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T3</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>11</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.50</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_TierIV</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>perfect hero staff</label>
    <description>A runed staff crowned with a brilliant crystal that throws cold light across the field. Glyphs crawl up the shaft as it answers the bearer's will, and any spell loosed through it strikes with redoubled force.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T4</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.30</drawSize></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>13</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.75</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_TierV</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>Codex Eterna</label>
    <description>The wizard's capstone focus, won only by a hero who has read the world down to its first runes. Crowned with a blazing arcane crystal and ringed by orbiting motes like a captive constellation, it does not so much amplify magic as recall it whole. With the Codex in hand, no spell lies beyond reach.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T5</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.35</drawSize></graphicData>
    <statBases><MarketValue>9000</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>16</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>1.0</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
