<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Class-locked hero staves for the wizard. Caster focus: weak melee, the power is in spell amplification (RH_SpellPower). Base RH_HeroWeaponMeleeBase is defined in Weapons_Barbarian.xml. -->

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_T1</defName>
    <label>lesser hero staff</label>
    <description>A plain wooden staff with a small bound stone lashed at its head. A poor club, but in a hero wizard's grip it focuses the weave and lends weight to their spells.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T1</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>8</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_T2</defName>
    <label>hero staff</label>
    <description>A silver-shod staff crowned with a cut blue gem. The stone drinks ambient mana, sharpening every incantation its bearer speaks.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T2</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>9</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_T3</defName>
    <label>greater hero staff</label>
    <description>An ornate staff whose silver claws cradle a floating orb that never quite touches its setting. A faint arcane glow trails the bearer, and their spells strike with a scholar's precision.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T3</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>11</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.50</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_T4</defName>
    <label>perfect hero staff</label>
    <description>A runed staff crowned with a brilliant crystal that sheds cold light across the field. Glyphs crawl up its shaft as it answers the bearer's will, and spent through it, every spell redoubles.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T4</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>13</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.75</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Wizard_T5</defName>
    <label>Codex Eterna</label>
    <description>The capstone focus of the wizard, won only by a hero who has read the world down to its first runes. Crowned with a blazing arcane crystal and ringed by orbiting motes like a captive constellation, it does not amplify magic so much as remember it. With the Codex in hand, no spell is beyond reach.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Wizard/T5</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
    <statBases><MarketValue>9000</MarketValue></statBases>
    <tools>
      <li><label>shaft</label><capacities><li>Blunt</li></capacities><power>16</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>1.0</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Wizard</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
