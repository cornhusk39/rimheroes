<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Class-locked hero longbows for the Ranger. Ranged (mirrors vanilla Bow_Great / Arrow_Great).
       Half-caster: equipping grants RH_SpellPower. Bound items: no smelt, no trade. -->

  <ThingDef ParentName="BaseWeaponNeolithic">
    <defName>RH_Weapon_Ranger_T1</defName>
    <equippedAngleOffset>180</equippedAngleOffset>
    <label>lesser hero longbow</label>
    <description>A tall selfbow of seasoned heartwood, drawing a far heavier pull than any common bow. It is bound to a hero ranger, and no one else can string it, let alone bend it.</description>
    <techLevel>Medieval</techLevel>
    <smeltable>false</smeltable>
    <tradeability>None</tradeability>
    <graphicData>
      <texPath>Things/RimHeroes/Weapons/Ranger/T1</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Bow_Large</soundInteract>
    <statBases>
      <MarketValue>700</MarketValue>
      <Mass>2.0</Mass>
      <AccuracyTouch>0.65</AccuracyTouch>
      <AccuracyShort>0.60</AccuracyShort>
      <AccuracyMedium>0.60</AccuracyMedium>
      <AccuracyLong>0.60</AccuracyLong>
      <RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
    </statBases>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <equippedStatOffsets>
      <RH_SpellPower>0.08</RH_SpellPower>
    </equippedStatOffsets>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Arrow_Great</defaultProjectile>
        <warmupTime>1.3</warmupTime>
        <range>30</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>Bow_Large</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <rotateInShelves>false</rotateInShelves>
    <modExtensions>
      <li Class="RimHeroes.WeaponLockExtension">
        <heroClass>RH_Ranger</heroClass>
        <minLevel>1</minLevel>
        <tier>1</tier>
      </li>
    </modExtensions>
  </ThingDef>

