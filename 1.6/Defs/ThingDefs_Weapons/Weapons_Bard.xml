<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Bard hero lutes: caster focus, weak melee, scaling RH_SpellPower. Base RH_HeroWeaponMeleeBase defined in Weapons_Barbarian.xml. -->

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Bard_T1</defName>
    <label>lesser hero lute</label>
    <description>A plain lute with a bowl carved from dark heartwood, bound to a hero bard. It will never win a melee, but even its first rough chords lend force to a bard's magic, steadying friends and unsettling foes.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Bard/T1</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>body</label><capacities><li>Blunt</li></capacities><power>7</power><cooldownTime>2.2</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Bard</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Bard_T2</defName>
    <label>hero lute</label>
    <description>A polished lute strung over gold frets, its soundhole ringed by a carved rosette. The tone carries clean across a battlefield, and the spellcraft riding each note bites harder than the lesser instrument could manage.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Bard/T2</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>body</label><capacities><li>Blunt</li></capacities><power>8</power><cooldownTime>2.2</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Bard</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Bard_T3</defName>
    <label>greater hero lute</label>
    <description>A richly inlaid lute crowned with a glowing gem above the rosette, a faint gold shimmer clinging to the strings. Any spell sung over its accompaniment lands with markedly greater weight.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Bard/T3</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>body</label><capacities><li>Blunt</li></capacities><power>10</power><cooldownTime>2.2</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.50</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Bard</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Bard_T4</defName>
    <label>perfect hero lute</label>
    <description>A lute alive with bound magic, golden notes drifting up unbidden from its blazing strings. Every chord pours raw power into the bard's spellcraft, enough that a single well-placed song can decide an entire fight.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Bard/T4</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>body</label><capacities><li>Blunt</li></capacities><power>12</power><cooldownTime>2.2</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.75</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Bard</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Bard_T5</defName>
    <label>Dirge of Kings</label>
    <description>The bard's capstone lute, granted only to a hero whose legend has reached its summit. It sings of its own accord, golden and unplayed; its inlay glitters like a crown, and motes of living music spill from the strings to amplify every spell its bearer weaves. When a master bard strikes the Dirge of Kings, armies kneel and empires recall how they were meant to end.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Bard/T5</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.30</drawSize></graphicData>
    <statBases><MarketValue>9000</MarketValue></statBases>
    <tools>
      <li><label>body</label><capacities><li>Blunt</li></capacities><power>15</power><cooldownTime>2.2</cooldownTime></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>1.0</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Bard</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
