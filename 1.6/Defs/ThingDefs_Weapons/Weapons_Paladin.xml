<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Paladin hero warhammer line: heavy half-caster blunt weapon (RH_HeroWeaponMeleeBase defined in Weapons_Barbarian.xml). -->

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Paladin_TierI</defName>
    <label>lesser hero warhammer</label>
    <description>A plain iron warhammer, blunt and brutally heavy in the hand. Bound to a hero paladin, it carries a faint thread of holy power for the one sworn to swing it.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Paladin/T1</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.10</drawSize></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <equippedStatOffsets><RH_SpellPower>0.08</RH_SpellPower></equippedStatOffsets>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>24</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.20</armorPenetration></li>
      <li><label>handle</label><capacities><li>Poke</li></capacities><power>10</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Paladin</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Paladin_TierII</defName>
    <label>hero warhammer</label>
    <description>A bright steel warhammer banded in royal blue, its head true and well-tempered. It hits harder than the lesser hammer and carries the paladin's faith with a steadier hand.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Paladin/T2</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.15</drawSize></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>32</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.28</armorPenetration></li>
      <li><label>handle</label><capacities><li>Poke</li></capacities><power>12</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Paladin</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Paladin_TierIII</defName>
    <label>greater hero warhammer</label>
    <description>A gold-engraved warhammer set with a royal sapphire, a holy light banked low within its head. It staves in heavy armour and lends real edge to the wielder's prayers.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Paladin/T3</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.15</drawSize></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <equippedStatOffsets><RH_SpellPower>0.22</RH_SpellPower></equippedStatOffsets>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>42</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.36</armorPenetration></li>
      <li><label>handle</label><capacities><li>Poke</li></capacities><power>14</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Paladin</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Paladin_TierIV</defName>
    <label>perfect hero warhammer</label>
    <description>A radiant warhammer wrapped in white-gold light, holy runes burning along its head. Every blow lands like a verdict, and the wielder's spells take on the heat of a borrowed dawn.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Paladin/T4</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.20</drawSize></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>54</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.45</armorPenetration></li>
      <li><label>handle</label><capacities><li>Poke</li></capacities><power>16</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Paladin</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Paladin_TierV</defName>
    <label>Dawnbreaker</label>
    <description>The paladin's capstone warhammer, won only by a hero whose legend has reached its full height. Its head blazes with the light of a breaking dawn; where it falls, the dark is simply undone, and the wielder's holy power burns brighter than it ever has.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Paladin/T5</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.30</drawSize></graphicData>
    <statBases><MarketValue>9000</MarketValue><Mass>4.2</Mass></statBases>
    <equippedStatOffsets><RH_SpellPower>0.40</RH_SpellPower></equippedStatOffsets>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>70</power><cooldownTime>2.4</cooldownTime><armorPenetration>0.60</armorPenetration></li>
      <li><label>handle</label><capacities><li>Poke</li></capacities><power>19</power><cooldownTime>2.0</cooldownTime></li>
    </tools>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Paladin</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
