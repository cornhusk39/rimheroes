<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Cleric hero maces: holy caster focus (RH_SpellPower) with a decent bludgeon. Base RH_HeroWeaponMeleeBase defined in Weapons_Barbarian.xml. -->

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Cleric_TierI</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>lesser hero mace</label>
    <description>A stout iron mace topped with a flanged sun-head, consecrated for a hero cleric's grip. It carries only the faintest thread of holy power, yet it still caves a skull without complaint.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Cleric/T1</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.05</drawSize></graphicData>
    <statBases><MarketValue>700</MarketValue></statBases>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>16</power><cooldownTime>2.2</cooldownTime><armorPenetration>0.12</armorPenetration></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.15</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Cleric</heroClass><minLevel>1</minLevel><tier>1</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Cleric_TierII</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>hero mace</label>
    <description>A silver-headed mace stamped with a gilded sun. The sigil seems to drink in every prayer spoken near it, and gives that strength back to the cleric's invocations.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Cleric/T2</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.05</drawSize></graphicData>
    <statBases><MarketValue>1400</MarketValue></statBases>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>20</power><cooldownTime>2.2</cooldownTime><armorPenetration>0.18</armorPenetration></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.30</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Cleric</heroClass><minLevel>5</minLevel><tier>2</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Cleric_TierIII</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>greater hero mace</label>
    <description>An ornate golden mace whose sun-head fans out in carved rays around a pale gem. A soft holy glow rests on the metal, and miracles answer its bearer faster than they have any right to.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Cleric/T3</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.10</drawSize></graphicData>
    <statBases><MarketValue>2600</MarketValue></statBases>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>26</power><cooldownTime>2.2</cooldownTime><armorPenetration>0.24</armorPenetration></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.50</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Cleric</heroClass><minLevel>10</minLevel><tier>3</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Cleric_TierIV</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>perfect hero mace</label>
    <description>A radiant mace whose sun-head casts real light, its rim ringed with burning runes and crowned in a halo of holy fire. In a cleric's hand it floods their prayers with power, steady and bright as a sunrise.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Cleric/T4</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.15</drawSize></graphicData>
    <statBases><MarketValue>4200</MarketValue></statBases>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>33</power><cooldownTime>2.2</cooldownTime><armorPenetration>0.30</armorPenetration></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>0.75</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Cleric</heroClass><minLevel>15</minLevel><tier>4</tier></li></modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_HeroWeaponMeleeBase">
    <defName>RH_Weapon_Cleric_TierV</defName>
    <equippedAngleOffset>270</equippedAngleOffset>
    <label>Lightbringer</label>
    <description>The cleric's capstone mace, its sunburst head blazing with a holy light that never dims. It comes only to a hero whose faith has run as deep as faith can go; its radiance throws back the dark, and one righteous blow is enough to break the wicked outright.</description>
    <graphicData><texPath>Things/RimHeroes/Weapons/Cleric/T5</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>1.30</drawSize></graphicData>
    <statBases><MarketValue>9000</MarketValue><Mass>4.2</Mass></statBases>
    <tools>
      <li><label>head</label><capacities><li>Blunt</li></capacities><power>42</power><cooldownTime>2.2</cooldownTime><armorPenetration>0.40</armorPenetration></li>
    </tools>
    <equippedStatOffsets><RH_SpellPower>1.0</RH_SpellPower></equippedStatOffsets>
    <modExtensions><li Class="RimHeroes.WeaponLockExtension"><heroClass>RH_Cleric</heroClass><minLevel>20</minLevel><tier>5</tier></li></modExtensions>
  </ThingDef>

</Defs>
