<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Crypt entrance: a MapPortal you send a party through to delve the instanced crypt below.
       Reuses Anomaly's CaveExit as the climb-out (placed by GenStep_CryptLayout). Placeholder art. -->

  <ThingDef ParentName="BuildingBase">
    <defName>RH_DungeonEntrance</defName>
    <label>crypt entrance</label>
    <description>A dark stairway descending into an ancient crypt. Send a party of heroes down to delve it; they can climb back out the way they came.</description>
    <thingClass>MapPortal</thingClass>
    <size>(3, 3)</size>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <useHitPoints>false</useHitPoints>
    <passability>Impassable</passability>
    <altitudeLayer>FloorEmplacement</altitudeLayer>
    <holdsRoof>false</holdsRoof>
    <castEdgeShadows>false</castEdgeShadows>
    <destroyable>false</destroyable>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/CryptEntrance</texPath>
      <drawSize>(3, 3)</drawSize>
    </graphicData>
    <building>
      <isEdifice>true</isEdifice>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
      <expandHomeArea>false</expandHomeArea>
      <isInert>true</isInert>
    </building>
    <portal>
      <pocketMapGenerator>RH_DungeonGen</pocketMapGenerator>
      <exitDef>CaveExit</exitDef>
      <enteredLetterLabel>Crypt entered</enteredLetterLabel>
      <enteredLetterText>Your party descends the worn stairs into the dark of the crypt.</enteredLetterText>
      <enteredLetterDef>NeutralEvent</enteredLetterDef>
    </portal>
    <inspectorTabs>
      <li>ITab_ContentsMapPortal</li>
    </inspectorTabs>
  </ThingDef>

  <!-- Everburning brazier: lights crypt rooms (placed one per room by GenStep_CryptPopulate). -->
  <ThingDef ParentName="BuildingBase">
    <defName>RH_Brazier</defName>
    <label>crypt brazier</label>
    <description>An everburning brazier that lights the dark of the crypt.</description>
    <size>(1, 1)</size>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.25</fillPercent>
    <useHitPoints>false</useHitPoints>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <castEdgeShadows>true</castEdgeShadows>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/Brazier</texPath>
      <drawSize>(1, 1)</drawSize>
    </graphicData>
    <building>
      <isEdifice>false</isEdifice>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
    </building>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>9</glowRadius>
        <glowColor>(95, 205, 235, 0)</glowColor>
      </li>
    </comps>
  </ThingDef>

  <!-- Boss-vault reliquary: a warded coffer holding the rare inlay drop behind a d20 lock. -->
  <ThingDef ParentName="BuildingBase">
    <defName>RH_Reliquary</defName>
    <label>warded reliquary</label>
    <description>An ancient coffer bound with sigil-locks, set in the heart of the vault. Whatever it guards is worth the warding. Send your finest hand to pick the lock.</description>
    <thingClass>RimHeroes.Building_Reliquary</thingClass>
    <size>(1, 1)</size>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.5</fillPercent>
    <useHitPoints>true</useHitPoints>
    <selectable>true</selectable>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/Reliquary</texPath>
      <drawSize>(1, 1)</drawSize>
    </graphicData>
    <building>
      <isEdifice>false</isEdifice>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
    </building>
  </ThingDef>

  <!-- Hidden dungeon traps: spot-then-save. See Building_DungeonTrap. Standable + invisible until
       revealed, so the party walks onto them unless someone spots them first. -->
  <ThingDef Name="RH_TrapBase" ParentName="BuildingBase" Abstract="True">
    <thingClass>RimHeroes.Building_DungeonTrap</thingClass>
    <size>(1, 1)</size>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <fillPercent>0</fillPercent>
    <useHitPoints>false</useHitPoints>
    <selectable>true</selectable>
    <rotatable>false</rotatable>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <altitudeLayer>FloorEmplacement</altitudeLayer>
    <castEdgeShadows>false</castEdgeShadows>
    <building>
      <isEdifice>false</isEdifice>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
      <expandHomeArea>false</expandHomeArea>
      <isInert>true</isInert>
    </building>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/Trap</texPath>
      <drawSize>(1, 1)</drawSize>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="RH_TrapBase">
    <defName>RH_Trap_Blade</defName>
    <label>scything blade trap</label>
    <description>A pressure plate wired to a hidden blade. Step on it unaware and it scythes across the floor.</description>
    <modExtensions>
      <li Class="RimHeroes.TrapExtension">
        <damage>Cut</damage>
        <damageAmount>16~28</damageAmount>
        <spotDC>12</spotDC>
        <saveDC>13</saveDC>
        <disarmDC>14</disarmDC>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="RH_TrapBase">
    <defName>RH_Trap_Dart</defName>
    <label>dart trap</label>
    <description>A near-invisible tripwire feeding a bank of spring-loaded darts. Subtle, and quick.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/Trap</texPath>
      <drawSize>(1, 1)</drawSize>
      <color>(0.62, 0.66, 0.72)</color>
    </graphicData>
    <modExtensions>
      <li Class="RimHeroes.TrapExtension">
        <damage>Stab</damage>
        <damageAmount>10~20</damageAmount>
        <spotDC>15</spotDC>
        <saveDC>12</saveDC>
        <disarmDC>13</disarmDC>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- Crypt loot chest: open it (gizmo) for treasure, or spring a mimic. thingClass handles both. -->
  <ThingDef ParentName="BuildingBase">
    <defName>RH_LootChest</defName>
    <label>crypt chest</label>
    <description>A bound chest left in the crypt. Most hold treasure. Some hold teeth.</description>
    <thingClass>RimHeroes.Building_LootChest</thingClass>
    <size>(1, 1)</size>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.4</fillPercent>
    <useHitPoints>true</useHitPoints>
    <selectable>true</selectable>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/RimHeroes/Items/Chest</texPath>
      <drawSize>(1, 1)</drawSize>
    </graphicData>
    <building>
      <isEdifice>false</isEdifice>
      <deconstructible>false</deconstructible>
      <claimable>false</claimable>
    </building>
  </ThingDef>

</Defs>
