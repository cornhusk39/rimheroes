<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- The full class roster. Mim trios per DESIGN.md (L3/L8/L12; L20 free choice in code
       later). Quiller and Wisp castes exist as jobs but have no race yet - those slots simply
       don't spawn until their castes ship. -->

  <RimHeroes.HeroClassDef>
    <defName>RH_Fighter</defName>
    <label>fighter</label>
    <description>A master of martial combat. Holds the line while others break.</description>
    <vestmentHediff>RH_Vestment_Fighter</vestmentHediff>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_HeroicVigor</li>
        </features>
      </li>
      <li>
        <level>5</level>
        <features>
          <li>RH_Feature_BattleHardened</li>
        </features>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Vanguard</job></li>
      <li><level>12</level><job>RH_Mim_Scrapper</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Barbarian</defName>
    <label>barbarian</label>
    <description>Fury given a body. Hits like a falling tree and barely notices being hit back.</description>
    <vestmentHediff>RH_Vestment_Barbarian</vestmentHediff>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_Rage</li>
        </features>
      </li>
      <li>
        <level>5</level>
        <features>
          <li>RH_Feature_BattleHardened</li>
        </features>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Hearth</job></li>
      <li><level>12</level><job>RH_Mim_Scrapper</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Monk</defName>
    <label>monk</label>
    <description>A weapon that walks. Speed and discipline in place of steel.</description>
    <vestmentHediff>RH_Vestment_Monk</vestmentHediff>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_UnarmoredSwiftness</li>
        </features>
      </li>
      <li>
        <level>5</level>
        <features>
          <li>RH_Feature_FlurryOfBlows</li>
        </features>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Hearth</job></li>
      <li><level>12</level><job>RH_Mim_Scrapper</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Rogue</defName>
    <label>rogue</label>
    <description>Where the armor isn't. Quick hands, quicker exits.</description>
    <vestmentHediff>RH_Vestment_Rogue</vestmentHediff>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_CunningEdge</li>
        </features>
      </li>
      <li>
        <level>5</level>
        <features>
          <li>RH_Feature_Evasion</li>
        </features>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Digger</job></li>
      <li><level>12</level><job>RH_Mim_Scrapper</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Ranger</defName>
    <label>ranger</label>
    <description>The wild's warden. Tracks anything, drops it from a treeline away.</description>
    <vestmentHediff>RH_Vestment_Ranger</vestmentHediff>
    <casterProgression>Half</casterProgression>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_Survivalist</li>
        </features>
      </li>
      <li>
        <level>2</level>
        <abilities>
          <li>RH_Spell_HuntersMark</li>
          <li>RH_Spell_CureWounds</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Hearth</job></li>
      <li><level>12</level><job>RH_Mim_Quiller</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Paladin</defName>
    <label>paladin</label>
    <description>An oath wearing armor. Stands between the helpless and the dark.</description>
    <vestmentHediff>RH_Vestment_Paladin</vestmentHediff>
    <casterProgression>Half</casterProgression>
    <preparesSpells>true</preparesSpells>
    <levelGrants>
      <li>
        <level>1</level>
        <features>
          <li>RH_Feature_DivineGrit</li>
        </features>
      </li>
      <li>
        <level>2</level>
        <abilities>
          <li>RH_Spell_LayOnHands</li>
          <li>RH_Spell_Bless</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Salve</job></li>
      <li><level>12</level><job>RH_Mim_Vanguard</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Cleric</defName>
    <label>cleric</label>
    <description>A conduit of the divine. Mends the broken - and, when the need is great, calls the dead back.</description>
    <vestmentHediff>RH_Vestment_Cleric</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <preparesSpells>true</preparesSpells>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <li>RH_Spell_SacredFlame</li>
          <li>RH_Spell_CureWounds</li>
          <li>RH_Spell_Bless</li>
        </abilities>
      </li>
      <li>
        <level>3</level>
        <abilities>
          <li>RH_Spell_Bane</li>
          <li>RH_Spell_LesserRestoration</li>
        </abilities>
      </li>
      <li>
        <level>5</level>
        <abilities>
          <li>RH_Spell_Revivify</li>
          <li>RH_Spell_PrayerOfHealing</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Hearth</job></li>
      <li><level>12</level><job>RH_Mim_Salve</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Druid</defName>
    <label>druid</label>
    <description>A voice of the wild. Wears the shapes of beasts and commands the green.</description>
    <vestmentHediff>RH_Vestment_Druid</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <preparesSpells>true</preparesSpells>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <li>RH_Spell_Thornlash</li>
          <li>RH_Spell_CureWounds</li>
        </abilities>
      </li>
      <li>
        <level>2</level>
        <abilities>
          <li>RH_Ability_WildshapeDireWolf</li>
        </abilities>
      </li>
      <li>
        <level>5</level>
        <abilities>
          <li>RH_Ability_WildshapeOwlbear</li>
        </abilities>
      </li>
      <li>
        <level>8</level>
        <abilities>
          <li>RH_Ability_WildshapeGiantElk</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Sprout</job></li>
      <li><level>12</level><job>RH_Mim_Salve</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Wizard</defName>
    <label>wizard</label>
    <description>A scholar of the arcane. Fragile, studious, and capable of erasing a raid before it closes the distance.</description>
    <vestmentHediff>RH_Vestment_Wizard</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <preparesSpells>true</preparesSpells>
    <arcaneRecovery>true</arcaneRecovery>
    <spellMastery>true</spellMastery>
    <signatureSpells>true</signatureSpells>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <!-- cantrips -->
          <li>RH_Spell_FireBolt</li>
          <li>RH_Spell_RayOfFrost</li>
          <li>RH_Spell_ShockingGrasp</li>
          <li>RH_Spell_TollTheDead</li>
          <!-- level-1 spells -->
          <li>RH_Spell_MagicMissile</li>
          <li>RH_Spell_MageArmor</li>
          <li>RH_Spell_Thunderwave</li>
          <li>RH_Spell_ChromaticOrb</li>
        </abilities>
      </li>
      <li>
        <level>3</level>
        <abilities>
          <!-- level-2 spells -->
          <li>RH_Spell_ScorchingRay</li>
          <li>RH_Spell_MistyStep</li>
          <li>RH_Spell_MirrorImage</li>
        </abilities>
      </li>
      <li>
        <level>5</level>
        <abilities>
          <!-- level-3 spells -->
          <li>RH_Spell_Fireball</li>
          <li>RH_Spell_LightningBolt</li>
          <li>RH_Spell_Haste</li>
        </abilities>
      </li>
      <li>
        <level>7</level>
        <abilities>
          <!-- level-4 spells -->
          <li>RH_Spell_IceStorm</li>
          <li>RH_Spell_Slow</li>
        </abilities>
      </li>
      <li>
        <level>9</level>
        <abilities>
          <!-- level-5 spells -->
          <li>RH_Spell_ConeOfCold</li>
          <li>RH_Spell_HoldMonster</li>
        </abilities>
      </li>
      <li>
        <level>11</level>
        <abilities>
          <!-- level-6 spells -->
          <li>RH_Spell_Disintegrate</li>
          <li>RH_Spell_ChainLightning</li>
        </abilities>
      </li>
      <li>
        <level>13</level>
        <abilities>
          <!-- level-7 spell -->
          <li>RH_Spell_DelayedBlastFireball</li>
        </abilities>
      </li>
      <li>
        <level>15</level>
        <abilities>
          <!-- level-8 spell -->
          <li>RH_Spell_IncendiaryCloud</li>
        </abilities>
      </li>
      <li>
        <level>17</level>
        <abilities>
          <!-- level-9 spells -->
          <li>RH_Spell_MeteorSwarm</li>
          <li>RH_Spell_PowerWordKill</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Vanguard</job></li>
      <li><level>12</level><job>RH_Mim_Wisp</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Sorcerer</defName>
    <label>sorcerer</label>
    <description>Magic in the blood, begging to get out. Less study than the wizard; more lightning.</description>
    <vestmentHediff>RH_Vestment_Sorcerer</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <li>RH_Spell_FireBolt</li>
          <li>RH_Spell_MagicMissile</li>
        </abilities>
      </li>
      <li>
        <level>5</level>
        <abilities>
          <li>RH_Spell_Fireball</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Vanguard</job></li>
      <li><level>12</level><job>RH_Mim_Wisp</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Bard</defName>
    <label>bard</label>
    <description>Wit sharp enough to wound and songs that close wounds. Better with friends.</description>
    <vestmentHediff>RH_Vestment_Bard</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <li>RH_Spell_ViciousMockery</li>
          <li>RH_Spell_HealingWord</li>
          <li>RH_Spell_Bless</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Hearth</job></li>
      <li><level>12</level><job>RH_Mim_Wisp</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

  <RimHeroes.HeroClassDef>
    <defName>RH_Warlock</defName>
    <label>warlock</label>
    <description>Power on loan from something that doesn't explain itself. The blast always works; that's the deal.</description>
    <vestmentHediff>RH_Vestment_Warlock</vestmentHediff>
    <casterProgression>Full</casterProgression>
    <levelGrants>
      <li>
        <level>1</level>
        <abilities>
          <li>RH_Spell_EldritchBlast</li>
          <li>RH_Spell_Hex</li>
        </abilities>
      </li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Sweeper</job></li>
      <li><level>8</level><job>RH_Mim_Digger</job></li>
      <li><level>12</level><job>RH_Mim_Wisp</job></li>
    </mimUnlocks>
  </RimHeroes.HeroClassDef>

</Defs>
