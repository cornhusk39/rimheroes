      </abilities></li>
      <li><level>2</level><abilities>
        <li>RH_Ability_ActionSurge</li>
      </abilities></li>
    </levelGrants>
    <mimUnlocks>
      <li><level>3</level><job>RH_Mim_Porter</job></li>
      <li><level>8</level><job>RH_Mim_Vanguard</job></li>
      <li><level>12</level><job>RH_Mim_Scrapper</job></li>
