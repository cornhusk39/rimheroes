<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Gestral main think tree: dryad-pattern survival/needs handling with vanilla
       JobGiver_Work driving real WorkGivers (gated per-caste by CompGestralWorker). -->
  <ThinkTreeDef>
    <defName>RH_Gestral</defName>
    <thinkRoot Class="ThinkNode_Priority">
      <subNodes>
        <li Class="ThinkNode_ConditionalMustKeepLyingDown">
          <subNodes>
            <li Class="JobGiver_KeepLyingDown" />
          </subNodes>
        </li>

        <li Class="ThinkNode_Subtree">
          <treeDef>Downed</treeDef>
        </li>

        <li Class="ThinkNode_Subtree">
          <treeDef>BurningResponse</treeDef>
        </li>

        <li Class="ThinkNode_Subtree">
          <treeDef>MentalStateCritical</treeDef>
        </li>

        <li Class="ThinkNode_Subtree">
          <treeDef>MentalStateNonCritical</treeDef>
        </li>

        <li Class="JobGiver_ReactToCloseMeleeThreat" />
        <li Class="ThinkNode_QueuedJob" />

        <!-- Master dead: frantic directionless panic for ~6h, then leave the map -->
        <li Class="RimHeroes.ThinkNode_ConditionalDevotionState">
          <state>Bereft</state>
          <subNodes>
            <li Class="RimHeroes.ThinkNode_ConditionalPanicLeaving">
              <subNodes>
                <li Class="ThinkNode_ConditionalCanReachMapEdge">
                  <subNodes>
                    <li Class="JobGiver_ExitMapRandom">
                      <defaultLocomotion>Jog</defaultLocomotion>
                    </li>
                  </subNodes>
                </li>
              </subNodes>
            </li>
            <li Class="JobGiver_WanderAnywhere">
              <maxDanger>Deadly</maxDanger>
              <ticksBetweenWandersRange>30~80</ticksBetweenWandersRange>
              <locomotionUrgency>Sprint</locomotionUrgency>
            </li>
          </subNodes>
        </li>

        <li Class="ThinkNode_Subtree">
          <treeDef>LordDuty</treeDef>
        </li>

        <!-- Needs before work so they eat/sleep -->
        <li Class="ThinkNode_Subtree">
          <treeDef>SatisfyBasicNeeds</treeDef>
        </li>

        <li Class="ThinkNode_ConditionalOfPlayerFaction">
          <subNodes>
            <li Class="ThinkNode_Tagger">
              <tagToGive>RestingForMedicalReasons</tagToGive>
              <subNodes>
                <li Class="JobGiver_PatientGoToBed" />
              </subNodes>
            </li>

            <!-- Master ailing: keep vigil at their side instead of working -->
            <li Class="RimHeroes.ThinkNode_ConditionalDevotionState">
              <state>Worried</state>
              <subNodes>
                <li Class="RimHeroes.JobGiver_VigilNearMaster" />
              </subNodes>
            </li>

            <!-- The work engine: emergency pass, then normal -->
            <li Class="JobGiver_Work">
              <emergency>true</emergency>
            </li>
            <li Class="JobGiver_Work" />

            <li Class="JobGiver_SeekAllowedArea" />
            <li Class="JobGiver_SeekSafeTemperature" />
          </subNodes>
        </li>

        <!-- Idle -->
        <li Class="ThinkNode_Tagger">
          <tagToGive>Idle</tagToGive>
          <subNodes>
            <li Class="JobGiver_WanderAnywhere">
              <maxDanger>Deadly</maxDanger>
              <ticksBetweenWandersRange>120~240</ticksBetweenWandersRange>
            </li>
          </subNodes>
        </li>

        <li Class="JobGiver_IdleError" />
      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>

</Defs>
