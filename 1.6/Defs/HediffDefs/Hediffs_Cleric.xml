<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Status hediffs introduced by the cleric spell list. Original flavor text.
       Timed via HediffCompProperties_Disappears. -->

  <!-- Guidance: a steadied ally aims and works better. -->
  <HediffDef>
    <defName>RH_Guided</defName>
    <label>guided</label>
    <description>A quiet thread of divine favor steadies their hands and sharpens their focus.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.9, 0.5)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
          <MeleeHitChance>2</MeleeHitChance>
        </statOffsets>
        <statFactors>
          <WorkSpeedGlobal>1.12</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1800</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Spirit Guardians: enemies harried by wheeling spirits. -->
  <HediffDef>
    <defName>RH_Harried</defName>
    <label>harried</label>
    <description>Spectral guardians wheel and strike around them, breaking their footing and fouling every blow.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.7, 0.85, 0.95)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.6</MoveSpeed>
          <MeleeHitChance>-3</MeleeHitChance>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>900</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Holy Aura: allies sheathed in protective radiance. -->
  <HediffDef>
    <defName>RH_HolyWard</defName>
    <label>holy ward</label>
    <description>A sheath of holy light clings to them, turning aside blows that would otherwise bite deep.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.0, 0.95, 0.6)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.2</ArmorRating_Blunt>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>2500</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

</Defs>
