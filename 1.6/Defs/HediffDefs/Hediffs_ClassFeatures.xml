<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- The single per-hero "class" hediff. Its label is set in code to the class name (Fighter,
       Wizard, ...) and its tooltip lists every active class effect. Passive stat effects that map to
       real pawn stats are applied via a dynamically-built stage in Hediff_ClassFeatures. -->
  <HediffDef>
    <defName>RH_ClassFeatures</defName>
    <label>class</label>
    <description>This hero's class training and signature techniques. Hover for the full list.</description>
    <hediffClass>RimHeroes.Hediff_ClassFeatures</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.7, 0.3)</defaultLabelColor>
    <stages>
      <li />
    </stages>
  </HediffDef>

  <!-- Fighter Action Surge: a brief surge of speed and striking power (melee bonus is applied by
       the melee patch while this is active; the move/work bonus is plain stat offsets here). -->
  <HediffDef>
    <defName>RH_ActionSurge</defName>
    <label>action surge</label>
    <description>A surge of battle focus - faster, harder-hitting, and quicker on their feet.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.0, 0.85, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>1.0</MoveSpeed>
        </statOffsets>
        <statFactors>
          <WorkSpeedGlobal>1.3</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>300</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

</Defs>
