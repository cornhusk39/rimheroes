<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Applied to every dungeon boss so it reads as a boss, not just a larger mook: tankier, hits
       harder, and shrugs off pain. Stacks on top of whatever the boss's own kit already provides. -->
  <HediffDef>
    <defName>RH_DungeonBoss</defName>
    <label>dungeon lord</label>
    <description>This creature is the master of its dungeon, far tougher and more dangerous than its lesser kin.</description>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.35, 0.2)</defaultLabelColor>
    <stages>
      <li>
        <statFactors>
          <IncomingDamageFactor>0.55</IncomingDamageFactor>
          <MeleeDamageFactor>1.4</MeleeDamageFactor>
        </statFactors>
        <statOffsets>
          <ArmorRating_Sharp>0.3</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.3</ArmorRating_Blunt>
          <PainShockThreshold>0.6</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
