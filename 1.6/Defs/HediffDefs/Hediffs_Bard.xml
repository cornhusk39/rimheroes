<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Status hediffs introduced by the Bard spell list. Original flavor text.
       RH_Held is reused from the Wizard list and is NOT re-authored here. -->

  <!-- Heroism: an ally surging with fearless valor. (buff) -->
  <HediffDef>
    <defName>RH_Heroism</defName>
    <label>heroism</label>
    <description>Buoyed by a swell of borrowed courage. They strike surer and stand firm where fear would break others.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.8, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MeleeHitChance>3</MeleeHitChance>
          <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
          <MentalBreakThreshold>-0.12</MentalBreakThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>7500</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Hypnotic Pattern: dazed and swaying. (debuff) -->
  <HediffDef>
    <defName>RH_Dazed</defName>
    <label>dazed</label>
    <description>Lost in a swirl of shifting light. They sway and stumble, slow to swing and slower to aim.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.8, 0.6, 0.95)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.5</MoveSpeed>
          <MeleeHitChance>-4</MeleeHitChance>
          <ShootingAccuracyPawn>-4</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>900</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Confusion: reeling, scattered, near to breaking. (debuff) -->
  <HediffDef>
    <defName>RH_Confused</defName>
    <label>confused</label>
    <description>Their thoughts will not hold still. They lurch about, fumbling every motion, nerves fraying toward panic.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.7, 0.55, 0.85)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.7</MoveSpeed>
          <MeleeHitChance>-5</MeleeHitChance>
          <MentalBreakThreshold>0.12</MentalBreakThreshold>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>900</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Inspiration: allies lifted by a stirring song. (buff) -->
  <HediffDef>
    <defName>RH_Inspired</defName>
    <label>inspired</label>
    <description>Carried by a rousing melody. Their aim sharpens, their blows land cleaner, and their hands move quicker at any work.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.85, 0.5)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MeleeHitChance>3</MeleeHitChance>
          <ShootingAccuracyPawn>3</ShootingAccuracyPawn>
        </statOffsets>
        <statFactors>
          <WorkSpeedGlobal>1.2</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>3600</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

</Defs>
