    <modExtensions>
      <li Class="RimHeroes.VestmentExtension"><baseColor>(0.42, 0.16, 0.52)</baseColor></li>
    </modExtensions>
  </HediffDef>

  <!-- Martial class features -->

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_Rage</defName>
    <label>battle fury</label>
    <description>This hero fights wrapped in a controlled fury: blows land harder, and pain is a distant rumor.</description>
    <stages>
      <li>
        <statFactors>
          <MeleeDamageFactor>1.15</MeleeDamageFactor>
          <IncomingDamageFactor>0.9</IncomingDamageFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_UnarmoredSwiftness</defName>
    <label>unarmored swiftness</label>
    <description>Trained motion as defense: this hero flows around blows that should have landed.</description>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>0.6</MoveSpeed>
          <MeleeDodgeChance>6</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_FlurryOfBlows</defName>
    <label>flurry of blows</label>
    <description>Strikes flow into strikes. This hero attacks notably faster than seems fair.</description>
    <stages>
      <li>
        <statFactors>
          <MeleeCooldownFactor>0.85</MeleeCooldownFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_CunningEdge</defName>
    <label>cunning edge</label>
    <description>This hero strikes where the armor isn't and is somewhere else by the time you swing back.</description>
    <stages>
      <li>
        <statOffsets>
          <MeleeHitChance>3</MeleeHitChance>
          <MoveSpeed>0.3</MoveSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_Evasion</defName>
    <label>evasion</label>
    <description>What should hit this hero, mostly doesn't.</description>
    <stages>
      <li>
        <statOffsets>
          <MeleeDodgeChance>8</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_Survivalist</defName>
    <label>survivalist</label>
    <description>At home in the wild: this hero moves lightly and shoots true.</description>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>0.2</MoveSpeed>
          <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="RH_FeatureBase">
    <defName>RH_Feature_DivineGrit</defName>
    <label>divine grit</label>
    <description>An oath holds this hero upright when flesh alone would fail.</description>
    <stages>
      <li>
        <statOffsets>
          <PainShockThreshold>0.2</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
