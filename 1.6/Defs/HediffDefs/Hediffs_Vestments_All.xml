<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Vestments for the remaining 11 classes. Martial template = Fighter's curve; caster
       template is lighter. All share the flak-vest placeholder visual, tinted per class. -->

  <HediffDef Name="RH_VestmentMartialBase" ParentName="RH_VestmentBase" Abstract="True">
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <label>battered harness</label>
        <statOffsets>
          <ArmorRating_Sharp>0.18</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </statOffsets>
      </li>
      <li>
        <minSeverity>1.5</minSeverity>
        <label>proven mail</label>
        <statOffsets>
          <ArmorRating_Sharp>0.30</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.18</ArmorRating_Blunt>
        </statOffsets>
      </li>
      <li>
        <minSeverity>2.5</minSeverity>
        <label>champion's plate</label>
        <statOffsets>
          <ArmorRating_Sharp>0.42</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.26</ArmorRating_Blunt>
          <ArmorRating_Heat>0.10</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>3.5</minSeverity>
        <label>mythic plate</label>
        <statOffsets>
          <ArmorRating_Sharp>0.55</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.34</ArmorRating_Blunt>
          <ArmorRating_Heat>0.20</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>4.5</minSeverity>
        <label>legend-forged panoply</label>
        <statOffsets>
          <ArmorRating_Sharp>0.70</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
          <ArmorRating_Heat>0.30</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_Vestment</nodeClass>
        <texPath>Things/Pawn/Humanlike/Apparel/FlakVest/FlakVest</texPath>
        <parentTagDef>Body</parentTagDef>
        <drawData>
          <defaultData>
            <layer>40</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

  <HediffDef Name="RH_VestmentCasterBase" ParentName="RH_VestmentBase" Abstract="True">
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <label>initiate's weave</label>
        <statOffsets>
          <ArmorRating_Sharp>0.10</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.06</ArmorRating_Blunt>
        </statOffsets>
      </li>
      <li>
        <minSeverity>1.5</minSeverity>
        <label>adept's weave</label>
        <statOffsets>
          <ArmorRating_Sharp>0.18</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </statOffsets>
      </li>
      <li>
        <minSeverity>2.5</minSeverity>
        <label>magister's weave</label>
        <statOffsets>
          <ArmorRating_Sharp>0.28</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.16</ArmorRating_Blunt>
          <ArmorRating_Heat>0.08</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>3.5</minSeverity>
        <label>archmage's raiment</label>
        <statOffsets>
          <ArmorRating_Sharp>0.38</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.22</ArmorRating_Blunt>
          <ArmorRating_Heat>0.15</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>4.5</minSeverity>
        <label>legend-woven regalia</label>
        <statOffsets>
          <ArmorRating_Sharp>0.50</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.30</ArmorRating_Blunt>
          <ArmorRating_Heat>0.25</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_Vestment</nodeClass>
        <texPath>Things/Pawn/Humanlike/Apparel/FlakVest/FlakVest</texPath>
        <parentTagDef>Body</parentTagDef>
        <drawData>
          <defaultData>
            <layer>40</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentMartialBase">
    <defName>RH_Vestment_Barbarian</defName>
    <label>barbarian's vestment</label>
    <description>A hero's war-harness, bound to their destiny. It grows with its bearer and cannot be removed; mundane torso armor cannot be worn over it.</description>
    <modExtensions>
      <li Class="RimHeroes.VestmentExtension">
        <baseColor>(0.72, 0.38, 0.16)</baseColor>
        <artDir>Barbarian</artDir>
      </li>
    </modExtensions>
    <renderNodeProperties>
      <li>
        <nodeClass>RimHeroes.PawnRenderNode_VestmentHelm</nodeClass>
        <parentTagDef>Head</parentTagDef>
        <drawData>
          <defaultData>
            <layer>75</layer>
          </defaultData>
        </drawData>
      </li>
    </renderNodeProperties>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentMartialBase">
    <defName>RH_Vestment_Monk</defName>
    <label>monk's vestment</label>
