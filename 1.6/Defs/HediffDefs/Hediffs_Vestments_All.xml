  </HediffDef>

  <HediffDef ParentName="RH_VestmentCasterBase">
    <defName>RH_Vestment_Druid</defName>
    <label>druid's vestment</label>
    <description>A hero's living mantle of bark and leaf, bound to the green. It grows with its bearer and cannot be removed; mundane torso armor cannot be worn over it.</description>
    <modExtensions>
      <li Class="RimHeroes.VestmentExtension"><baseColor>(0.3, 0.58, 0.3)</baseColor></li>
    </modExtensions>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentCasterBase">
    <defName>RH_Vestment_Wizard</defName>
    <label>wizard's vestment</label>
    <description>A hero's inscribed robes, bound to their study. They grow with their bearer and cannot be removed; mundane torso armor cannot be worn over them.</description>
    <modExtensions>
      <li Class="RimHeroes.VestmentExtension"><baseColor>(0.27, 0.37, 0.8)</baseColor></li>
    </modExtensions>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentCasterBase">
    <defName>RH_Vestment_Sorcerer</defName>
