    <modExtensions>
      <li Class="RimHeroes.VestmentExtension"><baseColor>(0.9, 0.66, 0.2)</baseColor></li>
    </modExtensions>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentMartialBase">
