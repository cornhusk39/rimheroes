    <description>A hero's flamboyant attire, bound to the song. It grows with its bearer and cannot be removed; mundane torso armor cannot be worn over it.</description>
    <modExtensions>
      <li Class="RimHeroes.VestmentExtension"><baseColor>(0.56, 0.32, 0.72)</baseColor></li>
    </modExtensions>
  </HediffDef>

  <HediffDef ParentName="RH_VestmentCasterBase">
    <defName>RH_Vestment_Warlock</defName>
