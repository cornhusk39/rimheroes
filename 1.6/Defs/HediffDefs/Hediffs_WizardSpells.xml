<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Status hediffs applied by the wizard spell list. Timed via HediffCompProperties_Disappears.
       Original flavor text. RH_Chilled (frost slow) lives in Hediffs_SpellEffects.xml and is reused. -->

  <!-- Shocking Grasp / Lightning Bolt / Chain Lightning: a brief electric stagger. -->
  <HediffDef>
    <defName>RH_Jolted</defName>
    <label>jolted</label>
    <description>Electricity still crawls through their muscles: twitchy, slow, and slow to react.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.9, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.6</MoveSpeed>
          <MeleeHitChance>-3</MeleeHitChance>
          <ShootingAccuracyPawn>-2</ShootingAccuracyPawn>
        </statOffsets>
        <capMods>
          <li><capacity>Manipulation</capacity><offset>-0.2</offset></li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>360</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Haste: a sped-up ally. -->
  <HediffDef>
    <defName>RH_Hasted</defName>
    <label>hasted</label>
    <description>Time bends around them. They move and act with blinding speed.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.5, 0.9, 1.0)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>1.0</MoveSpeed>
          <MeleeHitChance>3</MeleeHitChance>
          <MeleeDodgeChance>8</MeleeDodgeChance>
        </statOffsets>
        <statFactors>
          <WorkSpeedGlobal>1.3</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1800</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Slow: a bogged-down enemy. -->
  <HediffDef>
    <defName>RH_Slowed</defName>
    <label>slowed</label>
    <description>The air thickens to syrup around them. Every motion drags.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.5, 0.55, 0.7)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-1.3</MoveSpeed>
          <MeleeHitChance>-3</MeleeHitChance>
          <MeleeDodgeChance>-10</MeleeDodgeChance>
          <ShootingAccuracyPawn>-3</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1200</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Mirror Image: hard to hit while the duplicates last. -->
  <HediffDef>
    <defName>RH_MirrorImage</defName>
    <label>mirror images</label>
    <description>Flickering duplicates surround them, drawing blows away from the real body.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.6, 0.66, 1.0)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MeleeDodgeChance>30</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>2500</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Hold Monster: held fast - can't move or act. -->
  <HediffDef>
    <defName>RH_Held</defName>
    <label>held</label>
    <description>Bound rigid by arcane force. They cannot move and can barely act.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.7, 0.5, 0.9)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li><capacity>Moving</capacity><offset>-1.0</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.8</offset></li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>600</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

</Defs>
