<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- The progression engine. One per Hero pawn; stores class/level/XP and (later) slots, vestment, mim roster. -->
  <HediffDef>
    <defName>RH_HeroLevels</defName>
    <label>heroic destiny</label>
    <description>This pawn bears a class and a heroic destiny. Their experience, level, and class powers flow from this bond. Death itself hesitates: when mortally wounded, a hero fights for their life rather than dying outright.</description>
    <hediffClass>RimHeroes.Hediff_HeroLevels</hediffClass>
    <isBad>false</isBad>
    <preventsDeath>true</preventsDeath>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.7, 0.3)</defaultLabelColor>
  </HediffDef>

  <!-- Death saving throws: added automatically when a hero would otherwise be dead. -->
  <HediffDef>
    <defName>RH_DeathsDoor</defName>
    <label>at death's door</label>
    <description>This hero should be dead, and only destiny holds the line. Each hour they make a death saving throw. Three successes and they stabilize; three failures and even destiny lets go. Tended wounds improve the odds, and taking damage in this state counts as a failure.</description>
    <hediffClass>RimHeroes.Hediff_DeathsDoor</hediffClass>
    <isBad>true</isBad>
    <initialSeverity>0.5</initialSeverity>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.25, 0.25)</defaultLabelColor>
    <stages>
      <li>
        <label>fighting for life</label>
      </li>
    </stages>
  </HediffDef>

  <!-- The mim side of the bond: severity mirrors the master's condition. -->
  <HediffDef>
    <defName>RH_MimDevotion</defName>
    <label>devotion</label>
    <description>This mim is bound to a hero. Its spirits, and its diligence, rise and fall with its master's condition.</description>
    <hediffClass>RimHeroes.Hediff_MimDevotion</hediffClass>
    <isBad>false</isBad>
    <initialSeverity>0.1</initialSeverity>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.7, 0.3)</defaultLabelColor>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <label>content</label>
        <statFactors>
          <WorkSpeedGlobal>1.1</WorkSpeedGlobal>
        </statFactors>
      </li>
      <li>
        <minSeverity>0.3</minSeverity>
        <label>worried</label>
        <statFactors>
          <WorkSpeedGlobal>0.7</WorkSpeedGlobal>
          <MoveSpeed>0.9</MoveSpeed>
        </statFactors>
      </li>
      <li>
        <minSeverity>0.7</minSeverity>
        <label>bereft</label>
        <statFactors>
          <WorkSpeedGlobal>0.4</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>RH_Stabilized</defName>
    <label>stabilized by destiny</label>
    <description>This hero clawed their way back from death's door. They are out of immediate danger, though their wounds remain.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <initialSeverity>0.5</initialSeverity>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.85, 0.7, 0.3)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

</Defs>
