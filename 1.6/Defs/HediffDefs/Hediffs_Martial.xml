<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Buffs/debuffs from martial class abilities. Melee bonuses for Rage/Flurry are applied by the
       melee patch (it checks for the hediff); the stat lines here cover the rest. -->

  <!-- Barbarian Rage: damage resistance + toughness, at the cost of aim. (Melee bonus via patch.) -->
  <HediffDef>
    <defName>RH_Rage</defName>
    <label>raging</label>
    <description>A red fury: blows barely register and damage flows easily, though precision suffers.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.3, 0.2)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <PainShockThreshold>0.2</PainShockThreshold>
          <ShootingAccuracyPawn>-4</ShootingAccuracyPawn>
        </statOffsets>
        <statFactors>
          <IncomingDamageFactor>0.8</IncomingDamageFactor>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>1200</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Monk Flurry of Blows: a burst of fast, hard unarmed strikes (handled by the melee patch). -->
  <HediffDef>
    <defName>RH_Flurry</defName>
    <label>flurry of blows</label>
    <description>A blur of strikes, faster and harder than the eye can follow.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.0, 0.8, 0.4)</defaultLabelColor>
    <stages><li /></stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>180</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Monk Patient Defense -->
  <HediffDef>
    <defName>RH_PatientDefense</defName>
    <label>patient defense</label>
    <description>A still, ready stance - very hard to land a blow on.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.5, 0.7, 1.0)</defaultLabelColor>
    <stages>
      <li><statOffsets><MeleeDodgeChance>25</MeleeDodgeChance><ArmorRating_Sharp>0.2</ArmorRating_Sharp><ArmorRating_Blunt>0.2</ArmorRating_Blunt></statOffsets></li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>300</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Monk Step of the Wind -->
  <HediffDef>
    <defName>RH_StepWind</defName>
    <label>step of the wind</label>
    <description>Light as a gust - moving at blinding speed.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.6, 0.9, 0.9)</defaultLabelColor>
    <stages>
      <li><statOffsets><MoveSpeed>2.0</MoveSpeed></statOffsets></li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>300</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Monk Empty Body: hard to see and harder to hit (approximation of invisibility). -->
  <HediffDef>
    <defName>RH_EmptyBody</defName>
    <label>empty body</label>
    <description>Half-faded from sight - blows pass through where the body should be.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.8, 0.75, 1.0)</defaultLabelColor>
    <stages>
      <li><statOffsets><MeleeDodgeChance>40</MeleeDodgeChance><MoveSpeed>1.0</MoveSpeed></statOffsets></li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>600</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Rogue Cunning Action -->
  <HediffDef>
    <defName>RH_CunningAction</defName>
    <label>cunning action</label>
    <description>Darting and weaving - quick to reposition and slip away.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.6, 0.85, 0.6)</defaultLabelColor>
    <stages>
      <li><statOffsets><MoveSpeed>1.5</MoveSpeed><MeleeDodgeChance>15</MeleeDodgeChance></statOffsets></li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>300</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

  <!-- Monk Stunning Strike target: briefly stunned. -->
  <HediffDef>
    <defName>RH_Stunned</defName>
    <label>stunned</label>
    <description>Reeling from a precise blow - momentarily unable to move or fight.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.85, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li><capacity>Moving</capacity><offset>-1.0</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.8</offset></li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears"><disappearsAfterTicks>150</disappearsAfterTicks><showRemainingTime>true</showRemainingTime></li>
    </comps>
  </HediffDef>

</Defs>
