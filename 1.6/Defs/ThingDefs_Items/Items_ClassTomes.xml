<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Class Tomes: reading one makes a non-hero pawn a Hero of that class (HeroUtility.MakeHero).
       Acquisition: rare enemy-hero drops, exotic traders; quest rewards later. -->

  <ThingDef Name="RH_TomeBase" ParentName="ResourceBase" Abstract="True">
    <graphicData>
      <texPath>Things/Item/Book/Textbook/Textbook</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.9</drawSize>
    </graphicData>
    <stackLimit>1</stackLimit>
    <statBases>
      <MarketValue>1200</MarketValue>
      <Mass>1.5</Mass>
      <Flammability>1</Flammability>
      <DeteriorationRate>2</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeTags>
      <li>ExoticMisc</li>
    </tradeTags>
  </ThingDef>

  <ThingDef ParentName="RH_TomeBase">
    <defName>RH_Tome_Fighter</defName>
    <label>tome of the fighter</label>
    <description>A worn manual of legend. A pawn who studies it awakens as a Hero of the fighter's path - a destiny that cannot be undone.</description>
    <graphicData>
      <texPath>Things/Item/Book/Textbook/Textbook</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(0.78, 0.22, 0.18)</color>
      <drawSize>0.9</drawSize>
    </graphicData>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>UseItem</useJob>
        <useLabel>Study {0_label}</useLabel>
        <showUseGizmo>true</showUseGizmo>
      </li>
      <li Class="RimHeroes.CompProperties_UseEffectMakeHero">
        <heroClass>RH_Fighter</heroClass>
      </li>
      <li Class="CompProperties_UseEffectDestroySelf" />
    </comps>
  </ThingDef>

