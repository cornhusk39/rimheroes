<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Inlay items: consumed by vestment-inlay operations. One item + one recipe per inlay hediff.
       Acquisition: loot from enemy heroes (DESIGN.md), trade; crafting recipes later.
       Tints: defense blue, offense red, utility green; brighter per tier. -->

  <ThingDef Name="RH_InlayItemBase" ParentName="ResourceBase" Abstract="True">
    <graphicData>
      <texPath>Things/Item/Resource/ComponentIndustrial</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.85</drawSize>
    </graphicData>
    <stackLimit>10</stackLimit>
    <statBases>
      <Mass>1</Mass>
      <Flammability>0.4</Flammability>
      <DeteriorationRate>1</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeTags>
      <li>ExoticMisc</li>
    </tradeTags>
  </ThingDef>

  <RecipeDef Name="RH_InlayInstallBase" ParentName="SurgeryFlesh" Abstract="True">
    <workerClass>RimHeroes.Recipe_VestmentEnhancement</workerClass>
    <workAmount>2500</workAmount>
    <hideBodyPartNames>true</hideBodyPartNames>
    <isViolation>false</isViolation>
    <anesthetize>false</anesthetize>
    <skillRequirements>
      <Crafting>4</Crafting>
    </skillRequirements>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

  <!-- ===== Defense: Warding ===== -->

  <ThingDef ParentName="RH_InlayItemBase">
    <defName>RH_InlayItem_Warding_Lesser</defName>
    <label>lesser inlay of warding</label>
    <description>Faintly warded sigil-plates, sized for inlaying into a hero's vestment (defense slot).</description>
    <graphicData><texPath>Things/RimHeroes/Items/InlayDefense</texPath><graphicClass>Graphic_Single</graphicClass><color>(0.82, 0.82, 0.82)</color><drawSize>0.85</drawSize></graphicData>
    <statBases><MarketValue>200</MarketValue><Mass>1</Mass></statBases>
  </ThingDef>

  <ThingDef ParentName="RH_InlayItemBase">
    <defName>RH_InlayItem_Warding_Regular</defName>
    <label>inlay of warding</label>
    <description>Warded sigil-plates, sized for inlaying into a hero's vestment (defense slot).</description>
    <graphicData><texPath>Things/RimHeroes/Items/InlayDefense</texPath><graphicClass>Graphic_Single</graphicClass><color>(1.0, 1.0, 1.0)</color><drawSize>0.85</drawSize></graphicData>
    <statBases><MarketValue>350</MarketValue><Mass>1</Mass></statBases>
  </ThingDef>

  <ThingDef ParentName="RH_InlayItemBase">
    <defName>RH_InlayItem_Warding_Greater</defName>
    <label>greater inlay of warding</label>
    <description>Blazingly warded sigil-plates, sized for inlaying into a hero's vestment (defense slot).</description>
    <graphicData><texPath>Things/RimHeroes/Items/InlayDefense</texPath><graphicClass>Graphic_Single</graphicClass><color>(1.18, 1.18, 1.18)</color><drawSize>0.85</drawSize></graphicData>
    <statBases><MarketValue>600</MarketValue><Mass>1</Mass></statBases>
  </ThingDef>

  <RecipeDef ParentName="RH_InlayInstallBase">
    <defName>RH_Install_Warding_Lesser</defName>
    <label>inlay vestment: lesser warding</label>
    <description>Inlay lesser warding sigils into this hero's vestment (defense slot). Replaces any inlay already in that slot.</description>
    <jobString>Inlaying vestment with lesser warding.</jobString>
    <addsHediff>RH_Inlay_Warding_Lesser</addsHediff>
    <ingredients><li><filter><thingDefs><li>RH_InlayItem_Warding_Lesser</li></thingDefs></filter><count>1</count></li></ingredients>
    <fixedIngredientFilter><thingDefs><li>RH_InlayItem_Warding_Lesser</li></thingDefs></fixedIngredientFilter>
  </RecipeDef>

  <RecipeDef ParentName="RH_InlayInstallBase">
    <defName>RH_Install_Warding_Regular</defName>
    <label>inlay vestment: warding</label>
    <description>Inlay warding sigils into this hero's vestment (defense slot). Replaces any inlay already in that slot.</description>
    <jobString>Inlaying vestment with warding.</jobString>
    <addsHediff>RH_Inlay_Warding_Regular</addsHediff>
    <ingredients><li><filter><thingDefs><li>RH_InlayItem_Warding_Regular</li></thingDefs></filter><count>1</count></li></ingredients>
    <fixedIngredientFilter><thingDefs><li>RH_InlayItem_Warding_Regular</li></thingDefs></fixedIngredientFilter>
  </RecipeDef>

  <RecipeDef ParentName="RH_InlayInstallBase">
    <defName>RH_Install_Warding_Greater</defName>
    <label>inlay vestment: greater warding</label>
    <description>Inlay greater warding sigils into this hero's vestment (defense slot). Replaces any inlay already in that slot.</description>
