<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Mim race. Each caste has its own art under Things/RimHeroes/Mims/<Caste>/; only the
       dessicatedBodyGraphicData (the rarely-seen corpse sprite) falls back to the vanilla rat.
       One ThingDef per job caste so each carries its own CompMimWorker work-type allowlist
       (dryad pattern). -->

  <ThingDef Name="RH_MimBase" ParentName="AnimalThingBase" Abstract="True">
    <statBases>
      <MoveSpeed>4.2</MoveSpeed>
      <MarketValue>300</MarketValue>
      <ComfyTemperatureMin>-20</ComfyTemperatureMin>
      <ComfyTemperatureMax>50</ComfyTemperatureMax>
      <Wildness>0</Wildness>
    </statBases>
    <tools>
      <li>
        <label>teeth</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>3</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithPawsAndTail</body>
      <thinkTreeMain>RH_Mim</thinkTreeMain>
      <baseBodySize>0.55</baseBodySize>
      <baseHealthScale>0.6</baseHealthScale>
      <baseHungerRate>0.12</baseHungerRate>
      <foodType>OmnivoreRoughAnimal</foodType>
      <leatherDef>Leather_Light</leatherDef>
      <trainability>None</trainability>
      <petness>0</petness>
      <lifeExpectancy>80</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
    </race>
  </ThingDef>

  <PawnKindDef Name="RH_MimKindBase" ParentName="AnimalKindBase" Abstract="True">
    <combatPower>30</combatPower>
  </PawnKindDef>

  <!-- Porter: hauler -->
  <ThingDef ParentName="RH_MimBase">
    <defName>RH_MimPorter</defName>
    <label>porter mim</label>
    <description>A small, devoted helper creature that carries burdens so its master never has to.</description>
    <comps>
      <li Class="RimHeroes.CompProperties_MimWorker">
        <workTypes>
          <li>Hauling</li>
        </workTypes>
      </li>
    </comps>
  </ThingDef>

  <PawnKindDef ParentName="RH_MimKindBase">
    <defName>RH_MimPorterKind</defName>
    <label>porter mim</label>
    <race>RH_MimPorter</race>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Mims/Porter/Porter</texPath>
          <drawSize>1.1</drawSize>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Rat/Dessicated_Rat</texPath>
          <drawSize>1.0</drawSize>
        </dessicatedBodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <!-- Sweeper: cleaner -->
