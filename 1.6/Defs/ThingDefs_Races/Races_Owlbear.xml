<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Owlbear: D&D megafauna, balanced against the grizzly (body 2.15 / health 2.5 / claws 17 /
       bite 23.6 / wildness 0.8) - a touch stronger, meaner, and faster. Placeholder art: tinted
       bear texture. -->

  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_Owlbear</defName>
    <label>owlbear</label>
    <description>A monstrous cross of giant owl and bear: a feathered, beaked horror with a famously terrible attitude. Its screech-hoot carries for kilometers. Tameable in principle. In principle.</description>
    <statBases>
      <MoveSpeed>4.9</MoveSpeed>
      <ComfyTemperatureMin>-40</ComfyTemperatureMin>
      <ComfyTemperatureMax>40</ComfyTemperatureMax>
      <MarketValue>500</MarketValue>
      <Wildness>0.9</Wildness>
    </statBases>
    <tools>
      <li>
        <label>left claw</label>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>18</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
      </li>
      <li>
        <label>right claw</label>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>18</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
      </li>
      <li>
        <label>beak</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>25</power>
        <cooldownTime>2.6</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithPaws</body>
      <predator>true</predator>
      <maxPreyBodySize>1.2</maxPreyBodySize>
      <herdAnimal>false</herdAnimal>
      <baseBodySize>2.3</baseBodySize>
      <baseHungerRate>0.55</baseHungerRate>
      <baseHealthScale>2.6</baseHealthScale>
      <foodType>OmnivoreAnimal, OvivoreAnimal</foodType>
      <leatherDef>Leather_Bear</leatherDef>
      <trainability>Intermediate</trainability>
      <manhunterOnTameFailChance>0.40</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.65</manhunterOnDamageChance>
      <gestationPeriodDays>27</gestationPeriodDays>
      <lifeExpectancy>32</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.3</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.6</minAge>
          <soundWounded>Pawn_Bear_Injured</soundWounded>
          <soundDeath>Pawn_Bear_Death</soundDeath>
          <soundCall>Pawn_Bear_Call</soundCall>
          <soundAngry>Pawn_Bear_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
    </race>
    <tradeTags>
      <li>AnimalUncommon</li>
      <li>AnimalFighter</li>
    </tradeTags>
  </ThingDef>

