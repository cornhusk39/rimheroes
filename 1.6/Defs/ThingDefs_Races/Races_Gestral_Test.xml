<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Gestral race (placeholder rat art, tinted per job). One ThingDef per job caste so each
       carries its own CompGestralWorker work-type allowlist (dryad pattern). -->

  <ThingDef Name="RH_GestralBase" ParentName="AnimalThingBase" Abstract="True">
    <statBases>
      <MoveSpeed>4.2</MoveSpeed>
      <MarketValue>300</MarketValue>
      <ComfyTemperatureMin>-20</ComfyTemperatureMin>
      <ComfyTemperatureMax>50</ComfyTemperatureMax>
      <Wildness>0</Wildness>
    </statBases>
    <tools>
      <li>
        <label>teeth</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>3</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithPawsAndTail</body>
      <thinkTreeMain>RH_Gestral</thinkTreeMain>
      <baseBodySize>0.55</baseBodySize>
      <baseHealthScale>0.6</baseHealthScale>
      <baseHungerRate>0.12</baseHungerRate>
      <foodType>OmnivoreRoughAnimal</foodType>
      <leatherDef>Leather_Light</leatherDef>
      <trainability>None</trainability>
      <petness>0</petness>
      <lifeExpectancy>80</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
    </race>
  </ThingDef>

  <PawnKindDef Name="RH_GestralKindBase" ParentName="AnimalKindBase" Abstract="True">
    <combatPower>30</combatPower>
  </PawnKindDef>

  <!-- Porter: hauler -->
  <ThingDef ParentName="RH_GestralBase">
    <defName>RH_GestralPorter</defName>
    <label>porter gestral</label>
    <description>A small, devoted helper creature that carries burdens so its master never has to.</description>
    <comps>
      <li Class="RimHeroes.CompProperties_GestralWorker">
        <workTypes>
          <li>Hauling</li>
        </workTypes>
      </li>
    </comps>
  </ThingDef>

  <PawnKindDef ParentName="RH_GestralKindBase">
    <defName>RH_GestralPorterKind</defName>
    <label>porter gestral</label>
    <race>RH_GestralPorter</race>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Animal/Rat/Rat</texPath>
          <color>(170,140,95)</color>
          <drawSize>1.0</drawSize>
          <shaderType>CutoutComplex</shaderType>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Rat/Dessicated_Rat</texPath>
          <drawSize>1.0</drawSize>
        </dessicatedBodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <!-- Sweeper: cleaner -->
  <ThingDef ParentName="RH_GestralBase">
    <defName>RH_GestralSweeper</defName>
    <label>sweeper gestral</label>
    <description>A small, devoted helper creature that tidies relentlessly.</description>
    <comps>
      <li Class="RimHeroes.CompProperties_GestralWorker">
        <workTypes>
          <li>Cleaning</li>
        </workTypes>
      </li>
    </comps>
  </ThingDef>

  <PawnKindDef ParentName="RH_GestralKindBase">
    <defName>RH_GestralSweeperKind</defName>
    <label>sweeper gestral</label>
    <race>RH_GestralSweeper</race>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Animal/Rat/Rat</texPath>
          <color>(110,200,120)</color>
          <drawSize>1.0</drawSize>
          <shaderType>CutoutComplex</shaderType>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Rat/Dessicated_Rat</texPath>
          <drawSize>1.0</drawSize>
        </dessicatedBodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>
