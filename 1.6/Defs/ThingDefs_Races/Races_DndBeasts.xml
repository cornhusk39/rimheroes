  <!-- ===== Ankheg: armored burrowing monstrosity (NOT a valid wildshape) ===== -->
  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_Ankheg</defName>
    <label>ankheg</label>
    <description>A chitin-plated burrowing horror the size of a horse, all mandibles and acid-slick plates. It erupts from soil beneath its prey. Monstrosities like this are beyond any druid's shape.</description>
    <statBases>
      <MoveSpeed>4.2</MoveSpeed>
      <ComfyTemperatureMin>-10</ComfyTemperatureMin>
      <ComfyTemperatureMax>55</ComfyTemperatureMax>
      <MarketValue>500</MarketValue>
      <Wildness>0.95</Wildness>
      <ArmorRating_Sharp>0.25</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
    </statBases>
    <tools>
      <li>
        <label>mandibles</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>22</power>
        <cooldownTime>2.2</cooldownTime>
        <linkedBodyPartsGroup>Mouth</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.3</chanceFactor>
      </li>
    </tools>
    <race>
      <body>BeetleLike</body>
      <predator>true</predator>
      <maxPreyBodySize>1.2</maxPreyBodySize>
      <herdAnimal>false</herdAnimal>
      <baseBodySize>1.5</baseBodySize>
      <baseHungerRate>0.4</baseHungerRate>
      <baseHealthScale>1.8</baseHealthScale>
      <foodType>CarnivoreAnimal</foodType>
      <leatherDef>Leather_Lizard</leatherDef>
      <trainability>None</trainability>
      <manhunterOnTameFailChance>0.6</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.8</manhunterOnDamageChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>15</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>EusocialInsectLarva</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>EusocialInsectJuvenile</def>
          <minAge>0.2</minAge>
        </li>
        <li>
          <def>EusocialInsectAdult</def>
          <minAge>0.4</minAge>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

