        </dessicatedBodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/GiantElk/GiantElk</texPath>
          <drawSize>2.1</drawSize>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Elk/Dessicated_ElkMale</texPath>
          <drawSize>2.1</drawSize>
        </dessicatedBodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/GiantElk/GiantElk</texPath>
          <drawSize>2.9</drawSize>
          <shadowData>
            <volume>(0.7, 0.8, 0.7)</volume>
