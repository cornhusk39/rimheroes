  <!-- ===== Basilisk: armored reptile, slow and vicious (NOT a valid wildshape) ===== -->
  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_Basilisk</defName>
    <label>basilisk</label>
    <description>An eight-legged reptile with plated hide and a gaze that makes the blood run slow and cold. Travelers' tales of full petrification are... mostly exaggerated. Monstrosities like this are beyond any druid's shape.</description>
    <statBases>
      <MoveSpeed>3.6</MoveSpeed>
      <ComfyTemperatureMin>0</ComfyTemperatureMin>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <MarketValue>550</MarketValue>
      <Wildness>0.98</Wildness>
      <ArmorRating_Sharp>0.35</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.20</ArmorRating_Blunt>
    </statBases>
    <tools>
      <li>
        <label>venomous bite</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>24</power>
        <cooldownTime>2.5</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
      </li>
      <li>
        <label>tail</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2.2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.3</chanceFactor>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithPawsAndTail</body>
      <predator>true</predator>
      <maxPreyBodySize>1.0</maxPreyBodySize>
      <herdAnimal>false</herdAnimal>
      <baseBodySize>1.1</baseBodySize>
      <baseHungerRate>0.25</baseHungerRate>
      <baseHealthScale>1.7</baseHealthScale>
      <foodType>CarnivoreAnimal</foodType>
      <leatherDef>Leather_Lizard</leatherDef>
      <trainability>None</trainability>
      <manhunterOnTameFailChance>0.7</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.9</manhunterOnDamageChance>
      <gestationPeriodDays>22</gestationPeriodDays>
      <lifeExpectancy>40</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.25</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.5</minAge>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

