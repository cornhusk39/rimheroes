<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- D&D bestiary. Shapeable beasts (dire wolf, giant elk) and monstrosities druids cannot
       become (ankheg, basilisk). All placeholder art: tinted/scaled vanilla animal textures. -->

  <!-- ===== Dire Wolf: pack predator, balanced vs timber wolf +40% ===== -->
  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_DireWolf</defName>
    <label>dire wolf</label>
    <description>A wolf the size of a pony, with eyes that hold an unsettling intelligence. They hunt in coordinated packs and remember faces.</description>
    <statBases>
      <MoveSpeed>5.8</MoveSpeed>
      <ComfyTemperatureMin>-55</ComfyTemperatureMin>
      <ComfyTemperatureMax>35</ComfyTemperatureMax>
      <MarketValue>400</MarketValue>
      <Wildness>0.85</Wildness>
    </statBases>
    <tools>
      <li>
        <label>fangs</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>19</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithPaws</body>
      <predator>true</predator>
      <maxPreyBodySize>1.0</maxPreyBodySize>
      <herdAnimal>true</herdAnimal>
      <baseBodySize>1.25</baseBodySize>
      <baseHungerRate>0.35</baseHungerRate>
      <baseHealthScale>1.5</baseHealthScale>
      <foodType>CarnivoreAnimal, OvivoreAnimal</foodType>
      <leatherDef>Leather_Wolf</leatherDef>
      <trainability>Advanced</trainability>
      <manhunterOnTameFailChance>0.25</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.35</manhunterOnDamageChance>
      <gestationPeriodDays>20</gestationPeriodDays>
      <lifeExpectancy>20</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.25</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.5</minAge>
          <soundWounded>Pawn_Dog_Injured</soundWounded>
          <soundDeath>Pawn_Dog_Death</soundDeath>
          <soundCall>Pawn_Dog_Call</soundCall>
          <soundAngry>Pawn_Dog_Angry</soundAngry>
        </li>
      </lifeStageAges>
    </race>
    <tradeTags>
      <li>AnimalUncommon</li>
      <li>AnimalFighter</li>
    </tradeTags>
  </ThingDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>RH_DireWolfKind</defName>
    <label>dire wolf</label>
    <race>RH_DireWolf</race>
    <combatPower>110</combatPower>
    <ecoSystemWeight>0.9</ecoSystemWeight>
    <wildGroupSize>2~4</wildGroupSize>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/DireWolf/DireWolf</texPath>
          <drawSize>1.1</drawSize>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Wolf_Timber/Dessicated_Wolf_Timber</texPath>
          <drawSize>1.1</drawSize>
        </dessicatedBodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/DireWolf/DireWolf</texPath>
          <drawSize>1.45</drawSize>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Wolf_Timber/Dessicated_Wolf_Timber</texPath>
          <drawSize>1.45</drawSize>
        </dessicatedBodyGraphicData>
      </li>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/DireWolf/DireWolf</texPath>
          <drawSize>1.8</drawSize>
          <shadowData>
            <volume>(0.5, 0.5, 0.5)</volume>
          </shadowData>
        </bodyGraphicData>
        <dessicatedBodyGraphicData>
          <texPath>Things/Pawn/Animal/Wolf_Timber/Dessicated_Wolf_Timber</texPath>
          <drawSize>1.8</drawSize>
        </dessicatedBodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <!-- ===== Giant Elk: majestic herd herbivore, fast and strong ===== -->
  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_GiantElk</defName>
    <label>giant elk</label>
    <description>A towering elk whose antlers span a doorway. Old stories say meeting one is an omen - of what, the stories disagree.</description>
    <statBases>
      <MoveSpeed>6.0</MoveSpeed>
      <ComfyTemperatureMin>-50</ComfyTemperatureMin>
      <ComfyTemperatureMax>35</ComfyTemperatureMax>
      <MarketValue>450</MarketValue>
      <Wildness>0.75</Wildness>
    </statBases>
    <tools>
      <li>
        <label>antlers</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>2.3</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
      </li>
      <li>
        <label>front hooves</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
      </li>
    </tools>
    <race>
      <body>QuadrupedAnimalWithHooves</body>
      <herdAnimal>true</herdAnimal>
      <baseBodySize>2.4</baseBodySize>
      <baseHungerRate>0.85</baseHungerRate>
      <baseHealthScale>2.2</baseHealthScale>
      <foodType>VegetarianRoughAnimal</foodType>
      <leatherDef>Leather_Plain</leatherDef>
      <trainability>Intermediate</trainability>
      <manhunterOnTameFailChance>0.10</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.25</manhunterOnDamageChance>
      <gestationPeriodDays>28</gestationPeriodDays>
      <lifeExpectancy>26</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.3</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.6</minAge>
        </li>
      </lifeStageAges>
    </race>
    <tradeTags>
      <li>AnimalUncommon</li>
    </tradeTags>
  </ThingDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>RH_GiantElkKind</defName>
    <label>giant elk</label>
    <race>RH_GiantElk</race>
    <combatPower>150</combatPower>
    <ecoSystemWeight>1.4</ecoSystemWeight>
    <wildGroupSize>2~3</wildGroupSize>
    <lifeStages>
      <li>
