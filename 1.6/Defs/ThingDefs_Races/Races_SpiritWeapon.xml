<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Cleric's Spiritual Weapon: a floating spectral halberd, summoned to the caster's faction, that
       hunts and melees nearby enemies and otherwise stays at the caster's side. Dissolves after its
       lifespan (set by the spell). Rendered as a translucent glowing-gold weapon (single facing). -->
  <ThingDef ParentName="AnimalThingBase">
    <defName>RH_SpiritWeapon</defName>
    <label>spiritual weapon</label>
    <description>A weapon of pure force, conjured and bound to a cleric's will. It floats in the air and strikes at their foes until the magic sustaining it fades.</description>
    <statBases>
      <MoveSpeed>4.6</MoveSpeed>
      <ComfyTemperatureMin>-100</ComfyTemperatureMin>
      <ComfyTemperatureMax>250</ComfyTemperatureMax>
      <MarketValue>0</MarketValue>
      <Wildness>1.0</Wildness>
      <ArmorRating_Sharp>0.30</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.30</ArmorRating_Blunt>
      <PsychicSensitivity>0</PsychicSensitivity>
      <ToxicResistance>1</ToxicResistance>
    </statBases>
    <tools>
      <li>
        <label>blade</label>
        <capacities><li>Cut</li></capacities>
        <power>18</power>
        <cooldownTime>2.0</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
      </li>
      <li>
        <label>spike</label>
        <capacities><li>Stab</li></capacities>
        <power>15</power>
        <cooldownTime>2.2</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
      </li>
    </tools>
    <race>
      <thinkTreeMain>RH_ImpFamiliar</thinkTreeMain>
      <body>QuadrupedAnimalWithPaws</body>
      <baseBodySize>0.7</baseBodySize>
      <baseHungerRate>0.0</baseHungerRate>
      <baseHealthScale>0.75</baseHealthScale>
      <foodType>None</foodType>
      <trainability>None</trainability>
      <petness>0</petness>
      <nameOnTameChance>0</nameOnTameChance>
      <lifeExpectancy>50</lifeExpectancy>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <lifeStageAges>
        <li><def>AnimalAdult</def><minAge>0</minAge></li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>RH_SpiritWeaponKind</defName>
    <label>spiritual weapon</label>
    <race>RH_SpiritWeapon</race>
    <combatPower>60</combatPower>
    <canArriveManhunter>false</canArriveManhunter>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/RimHeroes/Beasts/SpiritWeapon/SpiritWeapon</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>TransparentPostLight</shaderType>
          <drawSize>1.5</drawSize>
          <color>(1, 0.95, 0.6, 0.45)</color>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>
